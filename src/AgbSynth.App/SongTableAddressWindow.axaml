<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AgbSynth.App.SongTableAddressWindow"
        Width="360"
        Height="292"
        MinWidth="360"
        MaxWidth="360"
        MinHeight="292"
        MaxHeight="292"
        CanResize="False"
        Title="MP2K Import Options"
        Background="{DynamicResource AppSurfaceAltBrush}">
  <Border Padding="12">
    <Border.Styles>
      <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
      </Style>
      <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="4,0,0,0"/>
      </Style>
      <Style Selector="Button">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Width" Value="72"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="CornerRadius" Value="0"/>
      </Style>
      <Style Selector="ComboBox">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="CornerRadius" Value="0"/>
      </Style>
    </Border.Styles>

    <Grid RowDefinitions="Auto,4,Auto,10,Auto,4,Auto,10,Auto,4,Auto,10,Auto,*,Auto">
      <TextBlock Text="Read Mode"/>
      <ComboBox x:Name="ReadModeComboBox"
                Grid.Row="2"
                SelectionChanged="OnReadModeSelectionChanged">
        <ComboBoxItem Content="Manual SongTable Address"/>
        <ComboBoxItem Content="Automatic MP2K Discovery"/>
      </ComboBox>

      <TextBlock Grid.Row="4"
                 Text="SongTable Address"/>
      <Grid x:Name="AddressInputGrid"
            Grid.Row="6"
            ColumnDefinitions="Auto,*">
        <TextBlock Text="0x"
                   VerticalAlignment="Center"
                   Margin="0,0,4,0"/>
        <TextBox x:Name="AddressTextBox"
                 Grid.Column="1"
                 Watermark="2C5638 or 082C5638"/>
      </Grid>
      <TextBlock Grid.Row="8" Text="Sequence Export"/>
      <ComboBox x:Name="SequenceFormatComboBox" Grid.Row="10">
        <ComboBoxItem Content="MIDI"/>
        <ComboBoxItem Content="Midi2agb (.s)"/>
        <ComboBoxItem Content="Both"/>
      </ComboBox>
      <CheckBox x:Name="IncludeUnreferencedCheckBox"
                Grid.Row="12"
                Content="Include unreferenced VoiceGroups"
                FontFamily="Consolas"
                FontSize="11"/>

      <TextBlock x:Name="ErrorTextBlock"
                 Grid.Row="13"
                 VerticalAlignment="Center"
                 Foreground="#FF8A8A"/>
      <StackPanel Grid.Row="14"
                  Orientation="Horizontal"
                  Spacing="8"
                  HorizontalAlignment="Right">
        <Button Content="Cancel"
                Click="OnCancelClicked"/>
        <Button Content="OK"
                Click="OnOkClicked"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
