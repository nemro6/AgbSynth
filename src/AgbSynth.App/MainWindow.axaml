            </Style>
            <Style Selector="Button.voiceGroupIconButton:disabled">
              <Setter Property="Opacity" Value="0.28"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
            <Style Selector="Path.voiceGroupIconPath">
              <Setter Property="Stroke" Value="{DynamicResource AppTextSecondaryBrush}"/>
              <Setter Property="StrokeThickness" Value="2"/>
              <Setter Property="StrokeLineCap" Value="Round"/>
              <Setter Property="StrokeJoin" Value="Round"/>
            </Style>
            <Style Selector="Path.voiceGroupMutedIconPath">
              <Setter Property="Stroke" Value="{DynamicResource AppTextMutedBrush}"/>
              <Setter Property="StrokeThickness" Value="1.6"/>
              <Setter Property="StrokeLineCap" Value="Round"/>
              <Setter Property="StrokeJoin" Value="Round"/>
            </Style>
            <Style Selector="ListBox.voiceGroupList">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Padding" Value="0"/>
            </Style>
            <Style Selector="ListBox.voiceGroupList ListBoxItem">
              <Setter Property="Height" Value="20"/>
              <Setter Property="MinHeight" Value="20"/>
              <Setter Property="Width" Value="984"/>
              <Setter Property="HorizontalAlignment" Value="Left"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            </Style>
            <Style Selector="ListBox.voiceGroupList ListBoxItem:selected">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="ListBox.voiceGroupList ListBoxItem:pointerover">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="TextBlock.voiceDetailLabel">
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
              <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style Selector="TextBox.voiceDetailField">
              <Setter Property="Height" Value="24"/>
              <Setter Property="MinHeight" Value="24"/>
              <Setter Property="Padding" Value="8,0"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="CornerRadius" Value="4"/>
              <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}"/>
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
              <Setter Property="ClipToBounds" Value="True"/>
            </Style>
            <Style Selector="TextBox.voiceDetailField:disabled">
              <Setter Property="Opacity" Value="0.45"/>
            </Style>
            <Style Selector="ComboBox.voiceDetailCombo">
              <Setter Property="Height" Value="24"/>
              <Setter Property="MinHeight" Value="24"/>
              <Setter Property="Padding" Value="8,0,0,0"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="CornerRadius" Value="4"/>
              <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}"/>
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            </Style>
            <Style Selector="ComboBox.voiceDetailCombo:disabled">
              <Setter Property="Opacity" Value="0.45"/>
            </Style>
            <Style Selector="Button.voiceDetailButton">
              <Setter Property="Height" Value="24"/>
              <Setter Property="MinHeight" Value="24"/>
              <Setter Property="Padding" Value="8,0"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="CornerRadius" Value="4"/>
              <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}"/>
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="HorizontalContentAlignment" Value="Left"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style Selector="Button.voiceDetailButton:pointerover">
              <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}"/>
            </Style>
            <Style Selector="Button.voiceDetailButton:pressed">
              <Setter Property="Background" Value="{DynamicResource AppControlPressedBrush}"/>
            </Style>
            <Style Selector="Button.voiceDetailButton:disabled">
              <Setter Property="Opacity" Value="0.45"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
            <Style Selector="Button.voiceDetailTinyButton">
              <Setter Property="Width" Value="24"/>
              <Setter Property="Height" Value="24"/>
              <Setter Property="MinWidth" Value="24"/>
              <Setter Property="MinHeight" Value="24"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="CornerRadius" Value="4"/>
              <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}"/>
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
              <Setter Property="HorizontalContentAlignment" Value="Center"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style Selector="Button.voiceDetailTinyButton:pointerover">
              <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}"/>
            </Style>
            <Style Selector="Button.voiceDetailTinyButton:pressed">
              <Setter Property="Background" Value="{DynamicResource AppControlPressedBrush}"/>
            </Style>
            <Style Selector="Button.voiceDetailTinyButton:disabled">
      <Setter Property="Opacity" Value="0.45"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ToggleButton.voiceTinyToggle">
              <Setter Property="Width" Value="12"/>
              <Setter Property="Height" Value="12"/>
              <Setter Property="MinWidth" Value="12"/>
              <Setter Property="MinHeight" Value="12"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0"/>
              <Setter Property="HorizontalAlignment" Value="Center"/>
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderBrush" Value="{DynamicResource AppDisabledBrush}"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="CornerRadius" Value="2"/>
              <Setter Property="Foreground" Value="Transparent"/>
              <Setter Property="HorizontalContentAlignment" Value="Center"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
              <Setter Property="Template">
                <ControlTemplate>
                  <Border Width="12"
                          Height="12"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}"/>
                </ControlTemplate>
              </Setter>
            </Style>
            <Style Selector="ToggleButton.voiceTinyToggle:pointerover">
              <Setter Property="Background" Value="{DynamicResource AppControlPressedBrush}"/>
              <Setter Property="BorderBrush" Value="{DynamicResource AppTextMutedBrush}"/>
            </Style>
            <Style Selector="ToggleButton.voiceTinyToggle:checked">
              <Setter Property="Background" Value="#6A7792"/>
              <Setter Property="BorderBrush" Value="#B8C9F5"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            </Style>
          </Border.Styles>

          <Border.Resources>
            <DataTemplate x:Key="VoiceGroupTemplate" x:DataType="vm:VoiceGroupOption">
              <TextBlock Text="{Binding FileDisplay}"
                         FontFamily="Consolas"
                         FontSize="10"
                         Foreground="{DynamicResource AppTextPrimaryBrush}"
                         TextTrimming="CharacterEllipsis"/>
            </DataTemplate>
            <DataTemplate x:Key="VoiceGroupVoiceRowTemplate" x:DataType="vm:VoiceRow">
              <Border Height="20"
                      Width="984"
                      HorizontalAlignment="Left"
                      Background="{Binding RowBackground}"
                      ClipToBounds="True"
                      PointerEntered="OnTableRowPointerEntered"
                      PointerExited="OnTableRowPointerExited"
                      PointerPressed="OnVoiceRowPointerPressed"
                      DoubleTapped="OnVoiceDoubleTapped">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Move Up" Click="OnVoiceRowMoveUpClicked"/>
                    <MenuItem Header="Move Down" Click="OnVoiceRowMoveDownClicked"/>
                    <Separator/>
                    <MenuItem Header="Copy" Click="OnVoiceRowCopyClicked"/>
                    <MenuItem Header="Paste" Click="OnVoiceRowPasteClicked"/>
                    <Separator/>
                    <MenuItem Header="Reset to Default" Click="OnVoiceRowResetClicked"/>
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid ColumnDefinitions="16,48,167,168,168,48,48,36,48,48,48,48,48,44">
                  <Border Grid.Column="0" Background="{DynamicResource AppTableHoverBrush}">
                    <TextBlock Classes="voiceGroupText"
                               Text="..."
                               FontSize="14"
                               HorizontalAlignment="Center"/>
                  </Border>
                  <Border Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBlock Classes="voiceGroupText" Text="{Binding IndexText}" HorizontalAlignment="Center"/>
                  </Border>
                  <Border Grid.Column="2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceGroupCell" Text="{Binding Label, Mode=TwoWay}"/>
                  </Border>
                  <Border Grid.Column="3" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <ComboBox Classes="voiceGroupCellCombo"
                              ItemsSource="{Binding AvailableTypeOptions}"
                              SelectedItem="{Binding SelectedTypeOption, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:VoiceTypeOption">
                          <TextBlock Text="{Binding Display}"
                                     FontFamily="Consolas"
                                     FontSize="10"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </Border>
                  <Border Grid.Column="4" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <Grid>
                      <Button Classes="voiceGroupDataButton"
                              IsVisible="{Binding IsFileDataVisible}"
                              Click="OnVoiceDataSelectClicked">
                        <TextBlock Text="{Binding DataDisplay}"
                                   TextTrimming="CharacterEllipsis"/>
                      </Button>
                      <ComboBox Classes="voiceGroupCellCombo"
                                IsVisible="{Binding IsPsgSquareDataVisible}"
                                ItemsSource="{Binding AvailableSquareDutyOptions}"
                                SelectedItem="{Binding SelectedSquareDutyOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="vm:VoiceDataOption">
                            <TextBlock Text="{Binding Display}"
                                       FontFamily="Consolas"
                                       FontSize="10"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <ComboBox Classes="voiceGroupCellCombo"
                                IsVisible="{Binding IsPsgNoiseDataVisible}"
                                ItemsSource="{Binding AvailableNoiseControlOptions}"
                                SelectedItem="{Binding SelectedNoiseControlOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="vm:VoiceDataOption">
                            <TextBlock Text="{Binding Display}"
                                       FontFamily="Consolas"
                                       FontSize="10"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </Grid>
                  </Border>
                  <Border Grid.Column="5" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceGroupCell voiceGroupNumberCell" Text="{Binding KeyName, Mode=TwoWay}" IsEnabled="{Binding IsBaseKeyEditable}"/>
                  </Border>
                  <Border Grid.Column="6" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceGroupCell voiceGroupNumberCell" Text="{Binding Length, Mode=TwoWay}"/>
                  </Border>
                  <Border Grid.Column="7" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <ToggleButton Classes="voiceTinyToggle"
                                  IsChecked="{Binding PanOverrideEnabled, Mode=TwoWay}"/>
                  </Border>
                  <Border Grid.Column="8" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceGroupCell voiceGroupNumberCell"
                             Text="{Binding PanSigned, Mode=TwoWay}"
                             IsEnabled="{Binding PanOverrideEnabled}"/>
                  </Border>
                  <Border Grid.Column="9" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceGroupCell voiceGroupNumberCell" Text="{Binding Attack, Mode=TwoWay}"/>
                  </Border>
                  <Border Grid.Column="10" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceGroupCell voiceGroupNumberCell" Text="{Binding Decay, Mode=TwoWay}"/>
                  </Border>
                  <Border Grid.Column="11" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceGroupCell voiceGroupNumberCell" Text="{Binding Sustain, Mode=TwoWay}"/>
                  </Border>
                  <Border Grid.Column="12" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceGroupCell voiceGroupNumberCell" Text="{Binding Release, Mode=TwoWay}"/>
                  </Border>
                  <Border Grid.Column="13">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="2">
                      <Button Classes="voiceGroupIconButton" Click="OnVoiceRowResetClicked" ToolTip.Tip="Reset to Square 1">
                        <Viewbox Width="13" Height="13">
                  <Canvas Width="16" Height="16">
                    <Path Classes="voiceGroupMutedIconPath"
                          Data="M9.75 6.25L6.25 9.75M6.25 6.25L9.75 9.75M13 8C13 10.7614 10.7614 13 8 13C5.23858 13 3 10.7614 3 8C3 5.23858 5.23858 3 8 3C10.7614 3 13 5.23858 13 8Z"/>
                  </Canvas>
                </Viewbox>
                      </Button>
                      <Button Classes="voiceGroupIconButton" Click="OnVoiceRowMoreClicked" ToolTip.Tip="More">
                        <Viewbox Width="14" Height="14">
                          <Canvas Width="16" Height="16">
                            <Path Classes="voiceGroupIconPath" StrokeThickness="1.6" Data="M8.00001 8.66667C8.3682 8.66667 8.66668 8.36819 8.66668 8.00001C8.66668 7.63182 8.3682 7.33334 8.00001 7.33334C7.63182 7.33334 7.33334 7.63182 7.33334 8.00001C7.33334 8.36819 7.63182 8.66667 8.00001 8.66667Z"/>
                            <Path Classes="voiceGroupIconPath" StrokeThickness="1.6" Data="M8.00001 4C8.3682 4 8.66668 3.70153 8.66668 3.33334C8.66668 2.96515 8.3682 2.66667 8.00001 2.66667C7.63182 2.66667 7.33334 2.96515 7.33334 3.33334C7.33334 3.70153 7.63182 4 8.00001 4Z"/>
                            <Path Classes="voiceGroupIconPath" StrokeThickness="1.6" Data="M8.00001 13.3333C8.3682 13.3333 8.66668 13.0349 8.66668 12.6667C8.66668 12.2985 8.3682 12 8.00001 12C7.63182 12 7.33334 12.2985 7.33334 12.6667C7.33334 13.0349 7.63182 13.3333 8.00001 13.3333Z"/>
                          </Canvas>
                        </Viewbox>
                      </Button>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </Border.Resources>

          <Grid Width="1004" HorizontalAlignment="Left" RowDefinitions="32,*,176,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,12,Auto,12,Auto,*,Auto" Margin="0,4,20,4">
              <ComboBox Grid.Column="0"
                        Classes="voiceGroupCombo"
                        ItemsSource="{Binding VoiceGroupOptions}"
                        SelectedItem="{Binding SelectedVoiceGroup, Mode=TwoWay}"
                        ItemTemplate="{StaticResource VoiceGroupTemplate}"/>
              <TextBox Grid.Column="2"
                       Classes="voiceGroupLabelBox"
                       Text="{Binding SelectedVoiceGroup.Label, Mode=TwoWay}"
                       Watermark="VoiceGroup Label"/>
              <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Classes="voiceGroupIconButton" Click="OnVoiceGroupAddClicked" ToolTip.Tip="New VoiceGroup">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceGroupIconPath" Data="M9.99996 6.66667V13.3333M6.66663 10H13.3333M18.3333 10C18.3333 14.6024 14.6023 18.3333 9.99996 18.3333C5.39759 18.3333 1.66663 14.6024 1.66663 10C1.66663 5.39763 5.39759 1.66667 9.99996 1.66667C14.6023 1.66667 18.3333 5.39763 18.3333 10Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceGroupIconButton" IsEnabled="{Binding CanEditSelectedVoiceGroup}" Click="OnVoiceGroupDuplicateClicked" ToolTip.Tip="Duplicate VoiceGroup">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceGroupIconPath" Data="M4.16663 12.5H3.33329C2.89127 12.5 2.46734 12.3244 2.15478 12.0118C1.84222 11.6993 1.66663 11.2754 1.66663 10.8333V3.33333C1.66663 2.89131 1.84222 2.46738 2.15478 2.15482C2.46734 1.84226 2.89127 1.66667 3.33329 1.66667H10.8333C11.2753 1.66667 11.6992 1.84226 12.0118 2.15482C12.3244 2.46738 12.5 2.89131 12.5 3.33333V4.16667M9.16663 7.5H16.6666C17.5871 7.5 18.3333 8.24619 18.3333 9.16667V16.6667C18.3333 17.5871 17.5871 18.3333 16.6666 18.3333H9.16663C8.24615 18.3333 7.49996 17.5871 7.49996 16.6667V9.16667C7.49996 8.24619 8.24615 7.5 9.16663 7.5Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceGroupIconButton" IsEnabled="{Binding CanEditSelectedVoiceGroup}" Click="OnVoiceGroupDeleteClicked" ToolTip.Tip="Delete VoiceGroup">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceGroupIconPath" Data="M2.5 5H4.16667M4.16667 5H17.5M4.16667 5L4.16667 16.6667C4.16667 17.1087 4.34226 17.5326 4.65482 17.8452C4.96738 18.1577 5.39131 18.3333 5.83333 18.3333H14.1667C14.6087 18.3333 15.0326 18.1577 15.3452 17.8452C15.6577 17.5326 15.8333 17.1087 15.8333 16.6667V5M6.66667 5V3.33333C6.66667 2.89131 6.84226 2.46738 7.15482 2.15482C7.46738 1.84226 7.89131 1.66667 8.33333 1.66667H11.6667C12.1087 1.66667 12.5326 1.84226 12.8452 2.15482C13.1577 2.46738 13.3333 2.89131 13.3333 3.33333V5M8.33333 9.16667V14.1667M11.6667 9.16667V14.1667"/>
                  </Viewbox>
                </Button>
              </StackPanel>
              <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Classes="voiceGroupIconButton" IsEnabled="{Binding CanEditSelectedVoice}" Click="OnVoiceMoveSelectedUpClicked" ToolTip.Tip="Move Voice Up">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceGroupIconPath" Data="M9.99996 15.8333V4.16666M15.8333 10L9.99996 4.16666L4.16663 10"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceGroupIconButton" IsEnabled="{Binding CanEditSelectedVoice}" Click="OnVoiceMoveSelectedDownClicked" ToolTip.Tip="Move Voice Down">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceGroupIconPath" Data="M9.99996 4.16666V15.8333M4.16663 10L9.99996 15.8333L15.8333 10"/>
                  </Viewbox>
                </Button>
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Width="1004" HorizontalAlignment="Left" RowDefinitions="22,*">
              <Grid Height="22"
                    Grid.Row="0"
                    Width="984"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource AppControlBackgroundBrush}"
                    ColumnDefinitions="16,48,167,168,168,48,48,36,48,48,48,48,48,44">
                <TextBlock Grid.Column="1" Classes="voiceGroupText" Text="Index" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Classes="voiceGroupText" Text="Label" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="3" Classes="voiceGroupText" Text="Type" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="4" Classes="voiceGroupText" Text="Data" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="5" Classes="voiceGroupText" Text="Key" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="6" Classes="voiceGroupText" Text="Len" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="7" Classes="voiceGroupText" Text="Fix" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="8" Classes="voiceGroupText" Text="Pan" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="9" Classes="voiceGroupText" Text="A" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="10" Classes="voiceGroupText" Text="D" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="11" Classes="voiceGroupText" Text="S" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="12" Classes="voiceGroupText" Text="R" HorizontalAlignment="Center"/>
              </Grid>
              <ListBox Grid.Row="1"
                       Classes="voiceGroupList"
                       ItemsSource="{Binding Voices}"
                       SelectedItem="{Binding SelectedVoice, Mode=TwoWay}"
                       ItemTemplate="{StaticResource VoiceGroupVoiceRowTemplate}"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
              </ListBox>
            </Grid>

            <Border Grid.Row="2"
                    Width="984"
                    Height="168"
                    Margin="0,8,20,0"
                    Padding="19,12"
                    Background="{DynamicResource AppSurfaceBrush}"
                    CornerRadius="8"
                    DataContext="{Binding SelectedVoice}">
              <Grid ColumnDefinitions="332,19,264,19,312">
                <Grid Grid.Column="0" RowDefinitions="41,8,41,8,41">
                  <Grid Grid.Row="0" ColumnDefinitions="56,8,200,8,24,4,24">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Index"/>
                      <TextBox Classes="voiceDetailField"
                               Text="{Binding IndexText}"
                               IsReadOnly="True"
                               IsHitTestVisible="False"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Label"/>
                      <TextBox Classes="voiceDetailField"
                               Text="{Binding Label, Mode=TwoWay}"/>
                    </StackPanel>
                    <Button Grid.Column="4"
                            Classes="voiceDetailTinyButton"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,1"
                            Click="OnVoicePreviousClicked"
                            ToolTip.Tip="Previous Voice">
                      <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                          <Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M15 6L9 12L15 18"/>
                        </Canvas>
                      </Viewbox>
                    </Button>
                    <Button Grid.Column="6"
                            Classes="voiceDetailTinyButton"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,1"
                            Click="OnVoiceNextClicked"
                            ToolTip.Tip="Next Voice">
                      <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                          <Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M9 6L15 12L9 18"/>
                        </Canvas>
                      </Viewbox>
                    </Button>
                  </Grid>

                  <Grid Grid.Row="2" ColumnDefinitions="244,8,80">
                    <StackPanel Grid.Column="0" Spacing="4" Width="244">
                      <TextBlock Classes="voiceDetailLabel" Text="InstType"/>
                      <ComboBox Classes="voiceDetailCombo"
                                Width="244"
                                ItemsSource="{Binding AvailableTypeOptions}"
                                SelectedItem="{Binding SelectedTypeOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="vm:VoiceTypeOption">
                            <TextBlock Text="{Binding Display}"
                                       FontFamily="Consolas"
                                       FontSize="10"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="BaseKey"/>
                      <Border Height="24"
                              Background="{DynamicResource AppControlBackgroundBrush}"
                              CornerRadius="4"
                              IsEnabled="{Binding IsBaseKeyEditable}"
                              Cursor="SizeWestEast"
                              PointerPressed="OnVoiceBaseKeyPointerPressed"
                              PointerMoved="OnVoiceBaseKeyPointerMoved"
                              PointerReleased="OnVoiceBaseKeyPointerReleased">
                        <TextBlock Text="{Binding KeyName}"
                                   Margin="8,0"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                      </Border>
                    </StackPanel>
                  </Grid>

                  <Grid Grid.Row="4" ColumnDefinitions="80,8,36,8,80,8,40">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Len"/>
                      <TextBox Classes="voiceDetailField"
                               Text="{Binding Length, Mode=TwoWay}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Fix"/>
                      <ToggleButton Classes="voiceTinyToggle"
                                    IsChecked="{Binding PanOverrideEnabled, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Pan"/>
                      <TextBox Classes="voiceDetailField"
                               Text="{Binding PanSigned, Mode=TwoWay}"
                               IsEnabled="{Binding PanOverrideEnabled}"/>
                    </StackPanel>
                    <controls:DialControl Grid.Column="6"
                                          Width="40"
                                          Height="40"
                                          VerticalAlignment="Bottom"
                                          Minimum="-64"
                                          Maximum="63"
                                          StartAngleDegrees="150"
                                          EndAngleDegrees="390"
                                          Value="{Binding PanSigned, Mode=TwoWay}"
                                          IsEnabled="{Binding PanOverrideEnabled}"/>
                  </Grid>
                </Grid>

                <Grid Grid.Column="2" RowDefinitions="41,8,73">
                  <Grid Grid.Row="0" ColumnDefinitions="232,8,24">
                    <StackPanel Grid.Column="0" Spacing="4" Width="232">
                      <TextBlock Classes="voiceDetailLabel" Text="Data"/>
                      <Grid Width="232" Height="24">
                        <Button Classes="voiceDetailButton"
                                Width="232"
                                IsVisible="{Binding IsFileDataVisible}"
                                Click="OnVoiceDataSelectClicked">
                          <TextBlock Text="{Binding DataDisplay}"
                                     TextTrimming="CharacterEllipsis"/>
                        </Button>
                        <ComboBox Classes="voiceDetailCombo"
                                  Width="232"
                                  IsVisible="{Binding IsPsgSquareDataVisible}"
                                  ItemsSource="{Binding AvailableSquareDutyOptions}"
                                  SelectedItem="{Binding SelectedSquareDutyOption, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:VoiceDataOption">
                              <TextBlock Text="{Binding Display}"
                                         FontFamily="Consolas"
                                         FontSize="10"/>
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox Classes="voiceDetailCombo"
                                  Width="232"
                                  IsVisible="{Binding IsPsgNoiseDataVisible}"
                                  ItemsSource="{Binding AvailableNoiseKindOptions}"
                                  SelectedItem="{Binding SelectedNoiseKindOption, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:VoiceDataOption">
                              <TextBlock Text="{Binding Display}"
                                         FontFamily="Consolas"
                                         FontSize="10"/>
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                      </Grid>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Classes="voiceDetailTinyButton"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,1"
                            IsVisible="{Binding IsFileDataVisible}"
                            Click="OnVoiceDataSelectClicked"
                            ToolTip.Tip="Browse Data">
                      <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                          <Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M4 6H9L11 8H20V18H4V6Z"/>
                        </Canvas>
                      </Viewbox>
                    </Button>
                  </Grid>
                  <StackPanel Grid.Row="2" Spacing="4">
                    <TextBlock Classes="voiceDetailLabel" Text="Overview"/>
                    <controls:VoiceOverviewControl Width="264"
                                                   Height="53"
                                                   Kind="{Binding OverviewKind}"
                                                   SquareDutyIndex="{Binding SquareDutyIndex}"
                                                   DataFilePath="{Binding DataFilePath}"
                                                   ProjectDirectory="{Binding ProjectDirectory}"/>
                  </StackPanel>
                </Grid>

                <Grid Grid.Column="4" RowDefinitions="73,8,66">
                  <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock Classes="voiceDetailLabel" Text="ADSR"/>
                    <controls:AdsrEnvelopeControl Width="312"
                                                  Height="53"
                                                  IsPsg="{Binding IsPsgAdsr}"
                                                  Attack="{Binding Attack, Mode=TwoWay}"
                                                  Decay="{Binding Decay, Mode=TwoWay}"
                                                  Sustain="{Binding Sustain, Mode=TwoWay}"
                                                  Release="{Binding Release, Mode=TwoWay}"/>
                  </StackPanel>
                  <Grid Grid.Row="2" ColumnDefinitions="56,24,56,24,56,24,56">
                    <Grid Grid.Column="0" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="A"/>
                        <TextBox Classes="voiceDetailField"
                                 Padding="4,0"
                                 Text="{Binding Attack, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2"
                                            Width="32"
                                            Height="32"
                                            VerticalAlignment="Bottom"
                                            Minimum="0"
                                            Maximum="255"
                                            StartAngleDegrees="150"
                                            EndAngleDegrees="390"
                                            Value="{Binding Attack, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Grid.Column="2" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="D"/>
                        <TextBox Classes="voiceDetailField"
                                 Padding="4,0"
                                 Text="{Binding Decay, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2"
                                            Width="32"
                                            Height="32"
                                            VerticalAlignment="Bottom"
                                            Minimum="0"
                                            Maximum="255"
                                            StartAngleDegrees="150"
                                            EndAngleDegrees="390"
                                            Value="{Binding Decay, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Grid.Column="4" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="S"/>
                        <TextBox Classes="voiceDetailField"
                                 Padding="4,0"
                                 Text="{Binding AdsrSustainText, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2"
                                            Width="32"
                                            Height="32"
                                            VerticalAlignment="Bottom"
                                            Minimum="0"
                                            Maximum="{Binding AdsrSustainMaximum}"
                                            StartAngleDegrees="150"
                                            EndAngleDegrees="390"
                                            Value="{Binding Sustain, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Grid.Column="6" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="R"/>
                        <TextBox Classes="voiceDetailField"
                                 Padding="4,0"
                                 Text="{Binding Release, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2"
                                            Width="32"
                                            Height="32"
                                            VerticalAlignment="Bottom"
                                            Minimum="0"
                                            Maximum="255"
                                            StartAngleDegrees="150"
                                            EndAngleDegrees="390"
                                            Value="{Binding Release, Mode=TwoWay}"/>
                    </Grid>
                  </Grid>
                </Grid>
              </Grid>
            </Border>

            <TextBlock Grid.Row="3"
                       Margin="0,8,0,0"
                       Text="{Binding VoiceGroupStatus}"
                       FontFamily="Consolas"
                       FontSize="11"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                       Opacity="0.8"
                       TextTrimming="CharacterEllipsis"/>
          </Grid>
        </Border>
      </TabItem>


      <TabItem Classes="hiddenNav">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Classes="sideNavIcon" Data="M21 2L19 4M19 4L22 7L18.5 10.5L15.5 7.5M19 4L15.5 7.5M11.39 11.61C11.9063 12.1195 12.3168 12.726 12.5978 13.3948C12.8787 14.0635 13.0246 14.7813 13.027 15.5066C13.0295 16.232 12.8884 16.9507 12.6119 17.6213C12.3354 18.2919 11.9291 18.9012 11.4161 19.4141C10.9032 19.9271 10.2939 20.3334 9.6233 20.6099C8.95268 20.8864 8.234 21.0275 7.50863 21.025C6.78327 21.0226 6.06554 20.8767 5.39679 20.5958C4.72804 20.3148 4.12147 19.9043 3.612 19.388C2.61013 18.3507 2.05576 16.9614 2.06829 15.5193C2.08082 14.0772 2.65925 12.6977 3.679 11.678C4.69874 10.6583 6.07821 10.0798 7.52029 10.0673C8.96238 10.0548 10.3517 10.6091 11.389 11.611L11.39 11.61ZM11.39 11.61L15.5 7.5"/>
            </Viewbox>
            <TextBlock Text="Key Split" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>
        </TabItem.Header>
        <Border Padding="0" Background="{DynamicResource AppWindowBackgroundBrush}">
          <Grid Width="1004" HorizontalAlignment="Left" RowDefinitions="32,*,168,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,12,Auto,12,Auto,*,Auto" Margin="0,4,20,4">
              <ComboBox Grid.Column="0"
                        Classes="voiceTableCombo"
                        ItemsSource="{Binding KeySplitOptions}"
                        SelectedItem="{Binding SelectedKeySplit, Mode=TwoWay}"
                        ItemTemplate="{StaticResource KeySplitOptionTemplate}"/>
              <TextBox Grid.Column="2"
                       Classes="voiceTableLabelBox"
                       Text="{Binding SelectedKeySplit.Label, Mode=TwoWay}"
                       Watermark="KeySplit Label"/>
              <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Classes="voiceTableIconButton" Click="OnKeySplitAddClicked" ToolTip.Tip="New KeySplit">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M9.99996 6.66667V13.3333M6.66663 10H13.3333M18.3333 10C18.3333 14.6024 14.6023 18.3333 9.99996 18.3333C5.39759 18.3333 1.66663 14.6024 1.66663 10C1.66663 5.39763 5.39759 1.66667 9.99996 1.66667C14.6023 1.66667 18.3333 5.39763 18.3333 10Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedKeySplit}" Click="OnKeySplitDuplicateClicked" ToolTip.Tip="Duplicate KeySplit">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M4.16663 12.5H3.33329C2.89127 12.5 2.46734 12.3244 2.15478 12.0118C1.84222 11.6993 1.66663 11.2754 1.66663 10.8333V3.33333C1.66663 2.89131 1.84222 2.46738 2.15478 2.15482C2.46734 1.84226 2.89127 1.66667 3.33329 1.66667H10.8333C11.2753 1.66667 11.6992 1.84226 12.0118 2.15482C12.3244 2.46738 12.5 2.89131 12.5 3.33333V4.16667M9.16663 7.5H16.6666C17.5871 7.5 18.3333 8.24619 18.3333 9.16667V16.6667C18.3333 17.5871 17.5871 18.3333 16.6666 18.3333H9.16663C8.24615 18.3333 7.49996 17.5871 7.49996 16.6667V9.16667C7.49996 8.24619 8.24615 7.5 9.16663 7.5Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedKeySplit}" Click="OnKeySplitDeleteClicked" ToolTip.Tip="Delete KeySplit">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M2.5 5H4.16667M4.16667 5H17.5M4.16667 5L4.16667 16.6667C4.16667 17.1087 4.34226 17.5326 4.65482 17.8452C4.96738 18.1577 5.39131 18.3333 5.83333 18.3333H14.1667C14.6087 18.3333 15.0326 18.1577 15.3452 17.8452C15.6577 17.5326 15.8333 17.1087 15.8333 16.6667V5M6.66667 5V3.33333C6.66667 2.89131 6.84226 2.46738 7.15482 2.15482C7.46738 1.84226 7.89131 1.66667 8.33333 1.66667H11.6667C12.1087 1.66667 12.5326 1.84226 12.8452 2.15482C13.1577 2.46738 13.3333 2.89131 13.3333 3.33333V5M8.33333 9.16667V14.1667M11.6667 9.16667V14.1667"/>
                  </Viewbox>
                </Button>
              </StackPanel>
              <StackPanel Grid.Column="6"
                          Orientation="Horizontal"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Right"
                          Spacing="8">
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedKeySplit}" Click="OnKeySplitInsertBelowSelectedClicked" ToolTip.Tip="Insert KeySplit Region Below">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M9.99996 6.66667V13.3333M6.66663 10H13.3333M18.3333 10C18.3333 14.6024 14.6023 18.3333 9.99996 18.3333C5.39759 18.3333 1.66663 14.6024 1.66663 10C1.66663 5.39763 5.39759 1.66667 9.99996 1.66667C14.6023 1.66667 18.3333 5.39763 18.3333 10Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedKeySplitVoice}" Click="OnKeySplitDuplicateSelectedRegionClicked" ToolTip.Tip="Duplicate KeySplit Region">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M4.16663 12.5H3.33329C2.89127 12.5 2.46734 12.3244 2.15478 12.0118C1.84222 11.6993 1.66663 11.2754 1.66663 10.8333V3.33333C1.66663 2.89131 1.84222 2.46738 2.15478 2.15482C2.46734 1.84226 2.89127 1.66667 3.33329 1.66667H10.8333C11.2753 1.66667 11.6992 1.84226 12.0118 2.15482C12.3244 2.46738 12.5 2.89131 12.5 3.33333V4.16667M9.16663 7.5H16.6666C17.5871 7.5 18.3333 8.24619 18.3333 9.16667V16.6667C18.3333 17.5871 17.5871 18.3333 16.6666 18.3333H9.16663C8.24615 18.3333 7.49996 17.5871 7.49996 16.6667V9.16667C7.49996 8.24619 8.24615 7.5 9.16663 7.5Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedKeySplitVoice}" Click="OnKeySplitDeleteSelectedRegionClicked" ToolTip.Tip="Delete KeySplit Region">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M2.5 5H4.16667M4.16667 5H17.5M4.16667 5L4.16667 16.6667C4.16667 17.1087 4.34226 17.5326 4.65482 17.8452C4.96738 18.1577 5.39131 18.3333 5.83333 18.3333H14.1667C14.6087 18.3333 15.0326 18.1577 15.3452 17.8452C15.6577 17.5326 15.8333 17.1087 15.8333 16.6667V5M6.66667 5V3.33333C6.66667 2.89131 6.84226 2.46738 7.15482 2.15482C7.46738 1.84226 7.89131 1.66667 8.33333 1.66667H11.6667C12.1087 1.66667 12.5326 1.84226 12.8452 2.15482C13.1577 2.46738 13.3333 2.89131 13.3333 3.33333V5M8.33333 9.16667V14.1667M11.6667 9.16667V14.1667"/>
                  </Viewbox>
                </Button>
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Width="1004" HorizontalAlignment="Left" RowDefinitions="22,*">
              <Grid Height="22"
                    Grid.Row="0"
                    Width="984"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource AppControlBackgroundBrush}"
                    ColumnDefinitions="16,48,180,168,183,48,48,36,48,40,40,40,40,44">
                <TextBlock Grid.Column="1" Classes="voiceTableText" Text="Index" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Classes="voiceTableText" Text="Label" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="3" Classes="voiceTableText" Text="Type" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="4" Classes="voiceTableText" Text="Data" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="5" Classes="voiceTableText" Text="Key" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="6" Classes="voiceTableText" Text="Len" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="7" Classes="voiceTableText" Text="Fix" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="8" Classes="voiceTableText" Text="Pan" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="9" Classes="voiceTableText" Text="A" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="10" Classes="voiceTableText" Text="D" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="11" Classes="voiceTableText" Text="S" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="12" Classes="voiceTableText" Text="R" HorizontalAlignment="Center"/>
              </Grid>
              <ListBox Grid.Row="1"
                       Classes="voiceTableList"
                       ItemsSource="{Binding KeySplitRows}"
                       SelectedItem="{Binding SelectedKeySplitVoice, Mode=TwoWay}"
                       ItemTemplate="{StaticResource KeySplitVoiceRowTemplate}"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
              </ListBox>
            </Grid>

            <Border Grid.Row="2"
                    Width="984"
                    Height="160"
                    Margin="0,8,20,0"
                    Padding="19,12"
                    Background="{DynamicResource AppSurfaceBrush}"
                    CornerRadius="8"
                    DataContext="{Binding SelectedKeySplitVoice}">
              <Grid ColumnDefinitions="332,19,264,19,312">
                <Grid Grid.Column="0" RowDefinitions="41,8,41,8,41">
                  <Grid Grid.Row="0" ColumnDefinitions="56,8,200,8,24,4,24">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Index"/>
                      <TextBox Classes="voiceDetailField" Text="{Binding IndexText}" IsReadOnly="True" IsHitTestVisible="False"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Label"/>
                      <TextBox Classes="voiceDetailField" Text="{Binding Label, Mode=TwoWay}"/>
                    </StackPanel>
                    <Button Grid.Column="4" Classes="voiceDetailTinyButton" VerticalAlignment="Bottom" Margin="0,0,0,1" Click="OnVoicePreviousClicked" ToolTip.Tip="Previous Region">
                      <Viewbox Width="16" Height="16"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M15 6L9 12L15 18"/></Canvas></Viewbox>
                    </Button>
                    <Button Grid.Column="6" Classes="voiceDetailTinyButton" VerticalAlignment="Bottom" Margin="0,0,0,1" Click="OnVoiceNextClicked" ToolTip.Tip="Next Region">
                      <Viewbox Width="16" Height="16"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M9 6L15 12L9 18"/></Canvas></Viewbox>
                    </Button>
                  </Grid>

                  <Grid Grid.Row="2" ColumnDefinitions="244,8,80">
                    <StackPanel Grid.Column="0" Spacing="4" Width="244">
                      <TextBlock Classes="voiceDetailLabel" Text="InstType"/>
                      <ComboBox Classes="voiceDetailCombo"
                                Width="244"
                                ItemsSource="{Binding AvailableTypeOptions}"
                                SelectedItem="{Binding SelectedTypeOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="vm:VoiceTypeOption">
                            <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="10"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="BaseKey"/>
                      <Border Height="24"
                              Background="{DynamicResource AppControlBackgroundBrush}"
                              CornerRadius="4"
                              IsEnabled="{Binding IsBaseKeyEditable}"
                              Cursor="SizeWestEast"
                              PointerPressed="OnVoiceBaseKeyPointerPressed"
                              PointerMoved="OnVoiceBaseKeyPointerMoved"
                              PointerReleased="OnVoiceBaseKeyPointerReleased">
                        <TextBlock Text="{Binding KeyName}" Margin="8,0" FontFamily="Consolas" FontSize="10" Foreground="{DynamicResource AppTextPrimaryBrush}" VerticalAlignment="Center"/>
                      </Border>
                    </StackPanel>
                  </Grid>

                  <Grid Grid.Row="4" ColumnDefinitions="80,8,36,8,80,8,40">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Len"/>
                      <TextBox Classes="voiceDetailField" Text="{Binding Length, Mode=TwoWay}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Fix"/>
                      <ToggleButton Classes="voiceTinyToggle" IsChecked="{Binding PanOverrideEnabled, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Pan"/>
                      <TextBox Classes="voiceDetailField" Text="{Binding PanSigned, Mode=TwoWay}" IsEnabled="{Binding PanOverrideEnabled}"/>
                    </StackPanel>
                    <controls:DialControl Grid.Column="6"
                                          Width="40"
                                          Height="40"
                                          VerticalAlignment="Bottom"
                                          Minimum="-64"
                                          Maximum="63"
                                          StartAngleDegrees="150"
                                          EndAngleDegrees="390"
                                          Value="{Binding PanSigned, Mode=TwoWay}"
                                          IsEnabled="{Binding PanOverrideEnabled}"/>
                  </Grid>
                </Grid>

                <Grid Grid.Column="2" RowDefinitions="41,8,73">
                  <Grid Grid.Row="0" ColumnDefinitions="232,8,24">
                    <StackPanel Grid.Column="0" Spacing="4" Width="232">
                      <TextBlock Classes="voiceDetailLabel" Text="Data"/>
                      <Grid Width="232" Height="24">
                        <Button Classes="voiceDetailButton" Width="232" IsVisible="{Binding IsFileDataVisible}" Click="OnVoiceDataSelectClicked">
                          <TextBlock Text="{Binding DataDisplay}" TextTrimming="CharacterEllipsis"/>
                        </Button>
                        <ComboBox Classes="voiceDetailCombo" Width="232" IsVisible="{Binding IsPsgSquareDataVisible}" ItemsSource="{Binding AvailableSquareDutyOptions}" SelectedItem="{Binding SelectedSquareDutyOption, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:VoiceDataOption">
                              <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="10"/>
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox Classes="voiceDetailCombo" Width="232" IsVisible="{Binding IsPsgNoiseDataVisible}" ItemsSource="{Binding AvailableNoiseKindOptions}" SelectedItem="{Binding SelectedNoiseKindOption, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:VoiceDataOption">
                              <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="10"/>
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                      </Grid>
                    </StackPanel>
                    <Button Grid.Column="2" Classes="voiceDetailTinyButton" VerticalAlignment="Bottom" Margin="0,0,0,1" IsVisible="{Binding IsFileDataVisible}" Click="OnVoiceDataSelectClicked" ToolTip.Tip="Browse Data">
                      <Viewbox Width="16" Height="16"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M4 6H9L11 8H20V18H4V6Z"/></Canvas></Viewbox>
                    </Button>
                  </Grid>
                  <StackPanel Grid.Row="2" Spacing="4">
                    <TextBlock Classes="voiceDetailLabel" Text="Overview"/>
                    <controls:VoiceOverviewControl Width="264"
                                                   Height="53"
                                                   Kind="{Binding OverviewKind}"
                                                   SquareDutyIndex="{Binding SquareDutyIndex}"
                                                   DataFilePath="{Binding DataFilePath}"
                                                   ProjectDirectory="{Binding ProjectDirectory}"/>
                  </StackPanel>
                </Grid>

                <Grid Grid.Column="4" RowDefinitions="73,8,66">
                  <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock Classes="voiceDetailLabel" Text="ADSR"/>
                    <controls:AdsrEnvelopeControl Width="312"
                                                  Height="53"
                                                  IsPsg="{Binding IsPsgAdsr}"
                                                  Attack="{Binding Attack, Mode=TwoWay}"
                                                  Decay="{Binding Decay, Mode=TwoWay}"
                                                  Sustain="{Binding Sustain, Mode=TwoWay}"
                                                  Release="{Binding Release, Mode=TwoWay}"/>
                  </StackPanel>
                  <Grid Grid.Row="2" ColumnDefinitions="56,24,56,24,56,24,56">
                    <Grid Grid.Column="0" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="A"/>
                        <TextBox Classes="voiceDetailField" Padding="4,0" Text="{Binding Attack, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2" Width="32" Height="32" VerticalAlignment="Bottom" Minimum="0" Maximum="255" StartAngleDegrees="150" EndAngleDegrees="390" Value="{Binding Attack, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Grid.Column="2" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="D"/>
                        <TextBox Classes="voiceDetailField" Padding="4,0" Text="{Binding Decay, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2" Width="32" Height="32" VerticalAlignment="Bottom" Minimum="0" Maximum="255" StartAngleDegrees="150" EndAngleDegrees="390" Value="{Binding Decay, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Grid.Column="4" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="S"/>
                        <TextBox Classes="voiceDetailField" Padding="4,0" Text="{Binding AdsrSustainText, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2" Width="32" Height="32" VerticalAlignment="Bottom" Minimum="0" Maximum="{Binding AdsrSustainMaximum}" StartAngleDegrees="150" EndAngleDegrees="390" Value="{Binding Sustain, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Grid.Column="6" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="R"/>
                        <TextBox Classes="voiceDetailField" Padding="4,0" Text="{Binding Release, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2" Width="32" Height="32" VerticalAlignment="Bottom" Minimum="0" Maximum="255" StartAngleDegrees="150" EndAngleDegrees="390" Value="{Binding Release, Mode=TwoWay}"/>
                    </Grid>
                  </Grid>
                </Grid>
              </Grid>
            </Border>

            <TextBlock Grid.Row="3"
                       Margin="0,8,0,0"
                       Text="{Binding KeySplitStatus}"
                       FontFamily="Consolas"
                       FontSize="11"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                       Opacity="0.8"
                       TextTrimming="CharacterEllipsis"/>
          </Grid>
        </Border>
      </TabItem>

      <TabItem Classes="hiddenNav">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Classes="sideNavIcon" Data="M3.27 6.96002L12 12.01L20.73 6.96002M12 22.08V12M21 16V8.00002C20.9996 7.6493 20.9071 7.30483 20.7315 7.00119C20.556 6.69754 20.3037 6.44539 20 6.27002L13 2.27002C12.696 2.09449 12.3511 2.00208 12 2.00208C11.6489 2.00208 11.304 2.09449 11 2.27002L4 6.27002C3.69626 6.44539 3.44398 6.69754 3.26846 7.00119C3.09294 7.30483 3.00036 7.6493 3 8.00002V16C3.00036 16.3508 3.09294 16.6952 3.26846 16.9989C3.44398 17.3025 3.69626 17.5547 4 17.73L11 21.73C11.304 21.9056 11.6489 21.998 12 21.998C12.3511 21.998 12.696 21.9056 13 21.73L20 17.73C20.3037 17.5547 20.556 17.3025 20.7315 16.9989C20.9071 16.6952 20.9996 16.3508 21 16Z"/>
            </Viewbox>
            <TextBlock Text="Drum Set" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>
        </TabItem.Header>
        <Border Padding="0" Background="{DynamicResource AppWindowBackgroundBrush}">
          <Grid Width="1004" HorizontalAlignment="Left" RowDefinitions="32,*,168,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,12,Auto,12,Auto,*,Auto" Margin="0,4,20,4">
              <ComboBox Grid.Column="0"
                        Classes="voiceTableCombo"
                        ItemsSource="{Binding DrumSetOptions}"
                        SelectedItem="{Binding SelectedDrumSet, Mode=TwoWay}"
                        ItemTemplate="{StaticResource DrumSetOptionTemplate}"/>
              <TextBox Grid.Column="2"
                       Classes="voiceTableLabelBox"
                       Text="{Binding SelectedDrumSet.Label, Mode=TwoWay}"
                       Watermark="DrumSet Label"/>
              <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Classes="voiceTableIconButton" Click="OnDrumSetAddClicked" ToolTip.Tip="New DrumSet">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M9.99996 6.66667V13.3333M6.66663 10H13.3333M18.3333 10C18.3333 14.6024 14.6023 18.3333 9.99996 18.3333C5.39759 18.3333 1.66663 14.6024 1.66663 10C1.66663 5.39763 5.39759 1.66667 9.99996 1.66667C14.6023 1.66667 18.3333 5.39763 18.3333 10Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedDrumSet}" Click="OnDrumSetDuplicateClicked" ToolTip.Tip="Duplicate DrumSet">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M4.16663 12.5H3.33329C2.89127 12.5 2.46734 12.3244 2.15478 12.0118C1.84222 11.6993 1.66663 11.2754 1.66663 10.8333V3.33333C1.66663 2.89131 1.84222 2.46738 2.15478 2.15482C2.46734 1.84226 2.89127 1.66667 3.33329 1.66667H10.8333C11.2753 1.66667 11.6992 1.84226 12.0118 2.15482C12.3244 2.46738 12.5 2.89131 12.5 3.33333V4.16667M9.16663 7.5H16.6666C17.5871 7.5 18.3333 8.24619 18.3333 9.16667V16.6667C18.3333 17.5871 17.5871 18.3333 16.6666 18.3333H9.16663C8.24615 18.3333 7.49996 17.5871 7.49996 16.6667V9.16667C7.49996 8.24619 8.24615 7.5 9.16663 7.5Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedDrumSet}" Click="OnDrumSetDeleteClicked" ToolTip.Tip="Delete DrumSet">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M2.5 5H4.16667M4.16667 5H17.5M4.16667 5L4.16667 16.6667C4.16667 17.1087 4.34226 17.5326 4.65482 17.8452C4.96738 18.1577 5.39131 18.3333 5.83333 18.3333H14.1667C14.6087 18.3333 15.0326 18.1577 15.3452 17.8452C15.6577 17.5326 15.8333 17.1087 15.8333 16.6667V5M6.66667 5V3.33333C6.66667 2.89131 6.84226 2.46738 7.15482 2.15482C7.46738 1.84226 7.89131 1.66667 8.33333 1.66667H11.6667C12.1087 1.66667 12.5326 1.84226 12.8452 2.15482C13.1577 2.46738 13.3333 2.89131 13.3333 3.33333V5M8.33333 9.16667V14.1667M11.6667 9.16667V14.1667"/>
                  </Viewbox>
                </Button>
              </StackPanel>
              <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Right">
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedDrumSetVoice}" Click="OnVoiceMoveSelectedUpClicked" ToolTip.Tip="Move Drum Voice Up">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M9.99996 15.8333V4.16666M15.8333 10L9.99996 4.16666L4.16663 10"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedDrumSetVoice}" Click="OnVoiceMoveSelectedDownClicked" ToolTip.Tip="Move Drum Voice Down">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M9.99996 4.16666V15.8333M4.16663 10L9.99996 15.8333L15.8333 10"/>
                  </Viewbox>
                </Button>
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Width="1004" HorizontalAlignment="Left" RowDefinitions="22,*">
              <Grid Height="22"
                    Grid.Row="0"
                    Width="984"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource AppControlBackgroundBrush}"
                    ColumnDefinitions="16,48,64,160,132,153,48,48,36,48,40,40,40,40,44">
                <TextBlock Grid.Column="1" Classes="voiceTableText" Text="Index" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Classes="voiceTableText" Text="Note" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="3" Classes="voiceTableText" Text="Label" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="4" Classes="voiceTableText" Text="Type" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="5" Classes="voiceTableText" Text="Data" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="6" Classes="voiceTableText" Text="Key" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="7" Classes="voiceTableText" Text="Len" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="8" Classes="voiceTableText" Text="Fix" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="9" Classes="voiceTableText" Text="Pan" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="10" Classes="voiceTableText" Text="A" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="11" Classes="voiceTableText" Text="D" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="12" Classes="voiceTableText" Text="S" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="13" Classes="voiceTableText" Text="R" HorizontalAlignment="Center"/>
              </Grid>
              <ListBox Grid.Row="1"
                       Classes="voiceTableList"
                       ItemsSource="{Binding DrumSetRows}"
                       SelectedItem="{Binding SelectedDrumSetVoice, Mode=TwoWay}"
                       ItemTemplate="{StaticResource VoiceTableRowTemplate}"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
              </ListBox>
            </Grid>

            <Border Grid.Row="2"
                    Width="984"
                    Height="160"
                    Margin="0,8,20,0"
                    Padding="19,12"
                    Background="{DynamicResource AppSurfaceBrush}"
                    CornerRadius="8"
                    DataContext="{Binding SelectedDrumSetVoice}">
              <Grid ColumnDefinitions="332,19,264,19,312">
                <Grid Grid.Column="0" RowDefinitions="41,8,41,8,41">
                  <Grid Grid.Row="0" ColumnDefinitions="56,8,200,8,24,4,24">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Index"/>
                      <TextBox Classes="voiceDetailField" Text="{Binding IndexText}" IsReadOnly="True" IsHitTestVisible="False"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Label"/>
                      <TextBox Classes="voiceDetailField" Text="{Binding Label, Mode=TwoWay}"/>
                    </StackPanel>
                    <Button Grid.Column="4" Classes="voiceDetailTinyButton" VerticalAlignment="Bottom" Margin="0,0,0,1" Click="OnVoicePreviousClicked" ToolTip.Tip="Previous Inst">
                      <Viewbox Width="16" Height="16"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M15 6L9 12L15 18"/></Canvas></Viewbox>
                    </Button>
                    <Button Grid.Column="6" Classes="voiceDetailTinyButton" VerticalAlignment="Bottom" Margin="0,0,0,1" Click="OnVoiceNextClicked" ToolTip.Tip="Next Inst">
                      <Viewbox Width="16" Height="16"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M9 6L15 12L9 18"/></Canvas></Viewbox>
                    </Button>
                  </Grid>

                  <Grid Grid.Row="2" ColumnDefinitions="244,8,80">
                    <StackPanel Grid.Column="0" Spacing="4" Width="244">
                      <TextBlock Classes="voiceDetailLabel" Text="InstType"/>
                      <ComboBox Classes="voiceDetailCombo"
                                Width="244"
                                ItemsSource="{Binding AvailableTypeOptions}"
                                SelectedItem="{Binding SelectedTypeOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="vm:VoiceTypeOption">
                            <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="10"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="BaseKey"/>
                      <Border Height="24"
                              Background="{DynamicResource AppControlBackgroundBrush}"
                              CornerRadius="4"
                              IsEnabled="{Binding IsBaseKeyEditable}"
                              Cursor="SizeWestEast"
                              PointerPressed="OnVoiceBaseKeyPointerPressed"
                              PointerMoved="OnVoiceBaseKeyPointerMoved"
                              PointerReleased="OnVoiceBaseKeyPointerReleased">
                        <TextBlock Text="{Binding KeyName}" Margin="8,0" FontFamily="Consolas" FontSize="10" Foreground="{DynamicResource AppTextPrimaryBrush}" VerticalAlignment="Center"/>
                      </Border>
                    </StackPanel>
                  </Grid>

                  <Grid Grid.Row="4" ColumnDefinitions="80,8,36,8,80,8,40">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Len"/>
                      <TextBox Classes="voiceDetailField" Text="{Binding Length, Mode=TwoWay}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Fix"/>
                      <ToggleButton Classes="voiceTinyToggle" IsChecked="{Binding PanOverrideEnabled, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Spacing="4">
                      <TextBlock Classes="voiceDetailLabel" Text="Pan"/>
                      <TextBox Classes="voiceDetailField" Text="{Binding PanSigned, Mode=TwoWay}" IsEnabled="{Binding PanOverrideEnabled}"/>
                    </StackPanel>
                    <controls:DialControl Grid.Column="6"
                                          Width="40"
                                          Height="40"
                                          VerticalAlignment="Bottom"
                                          Minimum="-64"
                                          Maximum="63"
                                          StartAngleDegrees="150"
                                          EndAngleDegrees="390"
                                          Value="{Binding PanSigned, Mode=TwoWay}"
                                          IsEnabled="{Binding PanOverrideEnabled}"/>
                  </Grid>
                </Grid>

                <Grid Grid.Column="2" RowDefinitions="41,8,73">
                  <Grid Grid.Row="0" ColumnDefinitions="232,8,24">
                    <StackPanel Grid.Column="0" Spacing="4" Width="232">
                      <TextBlock Classes="voiceDetailLabel" Text="Data"/>
                      <Grid Width="232" Height="24">
                        <Button Classes="voiceDetailButton" Width="232" IsVisible="{Binding IsFileDataVisible}" Click="OnVoiceDataSelectClicked">
                          <TextBlock Text="{Binding DataDisplay}" TextTrimming="CharacterEllipsis"/>
                        </Button>
                        <ComboBox Classes="voiceDetailCombo" Width="232" IsVisible="{Binding IsPsgSquareDataVisible}" ItemsSource="{Binding AvailableSquareDutyOptions}" SelectedItem="{Binding SelectedSquareDutyOption, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:VoiceDataOption">
                              <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="10"/>
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox Classes="voiceDetailCombo" Width="232" IsVisible="{Binding IsPsgNoiseDataVisible}" ItemsSource="{Binding AvailableNoiseKindOptions}" SelectedItem="{Binding SelectedNoiseKindOption, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:VoiceDataOption">
                              <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="10"/>
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                      </Grid>
                    </StackPanel>
                    <Button Grid.Column="2" Classes="voiceDetailTinyButton" VerticalAlignment="Bottom" Margin="0,0,0,1" IsVisible="{Binding IsFileDataVisible}" Click="OnVoiceDataSelectClicked" ToolTip.Tip="Browse Data">
                      <Viewbox Width="16" Height="16"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M4 6H9L11 8H20V18H4V6Z"/></Canvas></Viewbox>
                    </Button>
                  </Grid>
                  <StackPanel Grid.Row="2" Spacing="4">
                    <TextBlock Classes="voiceDetailLabel" Text="Overview"/>
                    <controls:VoiceOverviewControl Width="264"
                                                   Height="53"
                                                   Kind="{Binding OverviewKind}"
                                                   SquareDutyIndex="{Binding SquareDutyIndex}"
                                                   DataFilePath="{Binding DataFilePath}"
                                                   ProjectDirectory="{Binding ProjectDirectory}"/>
                  </StackPanel>
                </Grid>

                <Grid Grid.Column="4" RowDefinitions="73,8,66">
                  <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock Classes="voiceDetailLabel" Text="ADSR"/>
                    <controls:AdsrEnvelopeControl Width="312"
                                                  Height="53"
                                                  IsPsg="{Binding IsPsgAdsr}"
                                                  Attack="{Binding Attack, Mode=TwoWay}"
                                                  Decay="{Binding Decay, Mode=TwoWay}"
                                                  Sustain="{Binding Sustain, Mode=TwoWay}"
                                                  Release="{Binding Release, Mode=TwoWay}"/>
                  </StackPanel>
                  <Grid Grid.Row="2" ColumnDefinitions="56,24,56,24,56,24,56">
                    <Grid Grid.Column="0" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="A"/>
                        <TextBox Classes="voiceDetailField" Padding="4,0" Text="{Binding Attack, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2" Width="32" Height="32" VerticalAlignment="Bottom" Minimum="0" Maximum="255" StartAngleDegrees="150" EndAngleDegrees="390" Value="{Binding Attack, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Grid.Column="2" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="D"/>
                        <TextBox Classes="voiceDetailField" Padding="4,0" Text="{Binding Decay, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2" Width="32" Height="32" VerticalAlignment="Bottom" Minimum="0" Maximum="255" StartAngleDegrees="150" EndAngleDegrees="390" Value="{Binding Decay, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Grid.Column="4" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="S"/>
                        <TextBox Classes="voiceDetailField" Padding="4,0" Text="{Binding AdsrSustainText, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2" Width="32" Height="32" VerticalAlignment="Bottom" Minimum="0" Maximum="{Binding AdsrSustainMaximum}" StartAngleDegrees="150" EndAngleDegrees="390" Value="{Binding Sustain, Mode=TwoWay}"/>
                    </Grid>
                    <Grid Grid.Column="6" ColumnDefinitions="36,4,32">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="voiceDetailLabel" Text="R"/>
                        <TextBox Classes="voiceDetailField" Padding="4,0" Text="{Binding Release, Mode=TwoWay}"/>
                      </StackPanel>
                      <controls:DialControl Grid.Column="2" Width="32" Height="32" VerticalAlignment="Bottom" Minimum="0" Maximum="255" StartAngleDegrees="150" EndAngleDegrees="390" Value="{Binding Release, Mode=TwoWay}"/>
                    </Grid>
                  </Grid>
                </Grid>
              </Grid>
            </Border>
            <TextBlock Grid.Row="3"
                       Margin="0,8,0,0"
                       Text="{Binding DrumSetStatus}"
                       FontFamily="Consolas"
                       FontSize="11"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                       Opacity="0.8"
                       TextTrimming="CharacterEllipsis"/>
          </Grid>
        </Border>
      </TabItem>

      <TabItem Classes="hiddenNav">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Classes="sideNavIcon" Data="M22 12H18L15 21L9 3L6 12H2"/>
            </Viewbox>
            <TextBlock Text="Wave Memory" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>
        </TabItem.Header>
        <Border Padding="0" Background="{DynamicResource AppWindowBackgroundBrush}">
          <Border.Styles>
            <Style Selector="TextBlock.waveMemoryText">
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style Selector="TextBox.waveMemoryCell">
              <Setter Property="Height" Value="18"/>
              <Setter Property="MinHeight" Value="18"/>
              <Setter Property="MaxHeight" Value="18"/>
              <Setter Property="Padding" Value="4,0"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="CornerRadius" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="ClipToBounds" Value="True"/>
            </Style>
            <Style Selector="ListBox.waveMemoryList">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Padding" Value="0"/>
            </Style>
            <Style Selector="ListBox.waveMemoryList ListBoxItem">
              <Setter Property="Height" Value="20"/>
              <Setter Property="MinHeight" Value="20"/>
              <Setter Property="Width" Value="984"/>
              <Setter Property="HorizontalAlignment" Value="Left"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            </Style>
            <Style Selector="ListBox.waveMemoryList ListBoxItem:selected">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="ListBox.waveMemoryList ListBoxItem:pointerover">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
          </Border.Styles>

          <Border.Resources>
            <DataTemplate x:Key="WaveMemoryRowTemplate" x:DataType="vm:WaveMemoryRow">
              <Border Height="20"
                      Width="984"
                      HorizontalAlignment="Left"
                      Background="{Binding RowBackground}"
                      ClipToBounds="True"
                      PointerEntered="OnTableRowPointerEntered"
                      PointerExited="OnTableRowPointerExited"
                      PointerPressed="OnWaveMemoryRowPointerPressed">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Insert Above" Click="OnWaveMemoryRowInsertAboveClicked"/>
                    <MenuItem Header="Insert Below" Click="OnWaveMemoryRowInsertBelowClicked"/>
                    <MenuItem Header="Copy Row" Click="OnWaveMemoryRowCopyClicked"/>
                    <MenuItem Header="Paste Below" Click="OnWaveMemoryRowPasteClicked"/>
                    <Separator/>
                    <MenuItem Header="Delete" Click="OnWaveMemoryRowDeleteClicked"/>
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid ColumnDefinitions="48,120,180,230,96,266,44">
                  <Border Grid.Column="0" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBlock Classes="waveMemoryText" Text="{Binding IdText}" HorizontalAlignment="Center"/>
                  </Border>
                  <Border Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="waveMemoryCell" Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  </Border>
                  <Border Grid.Column="2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBlock Classes="waveMemoryText"
                               Text="{Binding FileDisplay}"
                               TextTrimming="CharacterEllipsis"
                               Margin="8,0,4,0"/>
                  </Border>
                  <Border Grid.Column="3" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBlock Classes="waveMemoryText"
                               Text="{Binding DataHexDisplay}"
                               TextTrimming="CharacterEllipsis"
                               Margin="8,0,4,0"/>
                  </Border>
                  <Border Grid.Column="4" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True" Padding="4,3">
                    <controls:WaveMemoryEditorControl DataHex="{Binding DataHex}"
                                                      Height="12"
                                                      VerticalAlignment="Center"
                                                      ClipToBounds="True"
                                                      IsHitTestVisible="False"/>
                  </Border>
                  <Border Grid.Column="5" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="waveMemoryCell" Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  </Border>
                  <Border Grid.Column="6">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="2">
                      <Button Classes="voiceTableIconButton" Click="OnWaveMemoryRowDeleteClicked">
                        <Viewbox Width="13" Height="13">
                  <Canvas Width="16" Height="16">
                    <Path Classes="voiceTableMutedIconPath"
                          Data="M9.75 6.25L6.25 9.75M6.25 6.25L9.75 9.75M13 8C13 10.7614 10.7614 13 8 13C5.23858 13 3 10.7614 3 8C3 5.23858 5.23858 3 8 3C10.7614 3 13 5.23858 13 8Z"/>
                  </Canvas>
                </Viewbox>
                      </Button>
                      <Button Classes="voiceTableIconButton" Click="OnWaveMemoryRowMoreClicked">
                        <Viewbox Width="14" Height="14">
                          <Canvas Width="16" Height="16">
                            <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 8.66667C8.3682 8.66667 8.66668 8.36819 8.66668 8.00001C8.66668 7.63182 8.3682 7.33334 8.00001 7.33334C7.63182 7.33334 7.33334 7.63182 7.33334 8.00001C7.33334 8.36819 7.63182 8.66667 8.00001 8.66667Z"/>
                            <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 4C8.3682 4 8.66668 3.70153 8.66668 3.33334C8.66668 2.96515 8.3682 2.66667 8.00001 2.66667C7.63182 2.66667 7.33334 2.96515 7.33334 3.33334C7.33334 3.70153 7.63182 4 8.00001 4Z"/>
                            <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 13.3333C8.3682 13.3333 8.66668 13.0349 8.66668 12.6667C8.66668 12.2985 8.3682 12 8.00001 12C7.63182 12 7.33334 12.2985 7.33334 12.6667C7.33334 13.0349 7.63182 13.3333 8.00001 13.3333Z"/>
                          </Canvas>
                        </Viewbox>
                      </Button>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </Border.Resources>

          <Grid Width="1004" HorizontalAlignment="Left" RowDefinitions="32,*,20,196,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="0,5,20,5"
                          HorizontalAlignment="Right">
                <Button Classes="voiceTableIconButton" Click="OnWaveMemoryInsertBelowSelectedClicked">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M9.99996 6.66667V13.3333M6.66663 10H13.3333M18.3333 10C18.3333 14.6024 14.6023 18.3333 9.99996 18.3333C5.39759 18.3333 1.66663 14.6024 1.66663 10C1.66663 5.39763 5.39759 1.66667 9.99996 1.66667C14.6023 1.66667 18.3333 5.39763 18.3333 10Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedWaveMemory}" Click="OnWaveMemoryDuplicateSelectedClicked">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M4.16663 12.5H3.33329C2.89127 12.5 2.46734 12.3244 2.15478 12.0118C1.84222 11.6993 1.66663 11.2754 1.66663 10.8333V3.33333C1.66663 2.89131 1.84222 2.46738 2.15478 2.15482C2.46734 1.84226 2.89127 1.66667 3.33329 1.66667H10.8333C11.2753 1.66667 11.6992 1.84226 12.0118 2.15482C12.3244 2.46738 12.5 2.89131 12.5 3.33333V4.16667M9.16663 7.5H16.6666C17.5871 7.5 18.3333 8.24619 18.3333 9.16667V16.6667C18.3333 17.5871 17.5871 18.3333 16.6666 18.3333H9.16663C8.24615 18.3333 7.49996 17.5871 7.49996 16.6667V9.16667C7.49996 8.24619 8.24615 7.5 9.16663 7.5Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedWaveMemory}" Click="OnWaveMemoryDeleteSelectedClicked">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M2.5 5H4.16667M4.16667 5H17.5M4.16667 5L4.16667 16.6667C4.16667 17.1087 4.34226 17.5326 4.65482 17.8452C4.96738 18.1577 5.39131 18.3333 5.83333 18.3333H14.1667C14.6087 18.3333 15.0326 18.1577 15.3452 17.8452C15.6577 17.5326 15.8333 17.1087 15.8333 16.6667V5M6.66667 5V3.33333C6.66667 2.89131 6.84226 2.46738 7.15482 2.15482C7.46738 1.84226 7.89131 1.66667 8.33333 1.66667H11.6667C12.1087 1.66667 12.5326 1.84226 12.8452 2.15482C13.1577 2.46738 13.3333 2.89131 13.3333 3.33333V5M8.33333 9.16667V14.1667M11.6667 9.16667V14.1667"/>
                  </Viewbox>
                </Button>
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Width="1004" HorizontalAlignment="Left" RowDefinitions="22,*">
              <Grid Height="22"
                    Grid.Row="0"
                    Width="984"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource AppControlBackgroundBrush}"
                    ColumnDefinitions="48,120,180,230,96,266,44">
                <TextBlock Grid.Column="0" Classes="waveMemoryText" Text="Index" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Classes="waveMemoryText" Text="Label" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="2" Classes="waveMemoryText" Text="File" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="3" Classes="waveMemoryText" Text="Binary Data" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="4" Classes="waveMemoryText" Text="Waveform" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="5" Classes="waveMemoryText" Text="Note" Margin="8,0,0,0"/>
              </Grid>
              <ListBox Grid.Row="1"
                       Classes="waveMemoryList"
                       ItemsSource="{Binding WaveMemoryRows}"
                       SelectedItem="{Binding SelectedWaveMemory, Mode=TwoWay}"
                       ItemTemplate="{StaticResource WaveMemoryRowTemplate}"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
              </ListBox>
            </Grid>

            <Button Grid.Row="2"
                    Classes="voiceTableIconButton"
                    HorizontalAlignment="Center"
                    Click="OnWaveMemoryAddEndClicked">
              <Viewbox Width="15" Height="15">
                <Path Classes="voiceTableIconPath"
                      Data="M9.99996 6.66667V13.3333M6.66663 10H13.3333M18.3333 10C18.3333 14.6024 14.6023 18.3333 9.99996 18.3333C5.39759 18.3333 1.66663 14.6024 1.66663 10C1.66663 5.39763 5.39759 1.66667 9.99996 1.66667C14.6023 1.66667 18.3333 5.39763 18.3333 10Z"/>
              </Viewbox>
            </Button>

            <Border Grid.Row="3"
                    Margin="0,10,20,0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    CornerRadius="6"
                    Padding="16"
                    DataContext="{Binding SelectedWaveMemory}">
              <Grid ColumnDefinitions="260,*,320" RowDefinitions="Auto,*" ColumnSpacing="18" RowSpacing="8">
                <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="64,*" RowSpacing="6">
                  <TextBlock Grid.Row="0" Grid.Column="0" Classes="voiceDetailLabel" Text="Index"/>
                  <TextBox Grid.Row="0" Grid.Column="1" Classes="voiceDetailField" Text="{Binding IdText}" IsReadOnly="True" IsHitTestVisible="False"/>
                  <TextBlock Grid.Row="1" Grid.Column="0" Classes="voiceDetailLabel" Text="Label"/>
                  <TextBox Grid.Row="1" Grid.Column="1" Classes="voiceDetailField" Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  <TextBlock Grid.Row="2" Grid.Column="0" Classes="voiceDetailLabel" Text="File"/>
                  <TextBox Grid.Row="2" Grid.Column="1" Classes="voiceDetailField" Text="{Binding FileDisplay}" IsReadOnly="True" IsHitTestVisible="False"/>
                  <TextBlock Grid.Row="3" Grid.Column="0" Classes="voiceDetailLabel" Text="Size"/>
                  <TextBox Grid.Row="3" Grid.Column="1" Classes="voiceDetailField" Text="{Binding ByteCountText}" IsReadOnly="True" IsHitTestVisible="False"/>
                  <TextBlock Grid.Row="4" Grid.Column="0" Classes="voiceDetailLabel" Text="Note"/>
                  <TextBox Grid.Row="4" Grid.Column="1" Classes="voiceDetailField" Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="6">
                  <TextBlock Grid.Row="0" Classes="voiceDetailLabel" Text="Binary Data"/>
                  <Border Grid.Row="1"
                          Background="{DynamicResource AppSurfaceAltBrush}"
                          BorderBrush="{DynamicResource AppBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="3"
                          Height="34"
                          ClipToBounds="True">
                    <TextBlock x:Name="WaveMemoryBinaryDataText"
                               Text="{Binding DataHexDisplay}"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="{DynamicResource AppTextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               TextTrimming="CharacterEllipsis"/>
                  </Border>
                  <TextBlock Grid.Row="2"
                             Text="Graph edits are kept in memory until project save is implemented."
                             FontFamily="Consolas"
                             FontSize="10"
                             Foreground="{DynamicResource AppTextMutedBrush}"/>
                </Grid>

                <Grid Grid.Column="2" RowDefinitions="Auto,*" RowSpacing="6">
                  <TextBlock Grid.Row="0" Classes="voiceDetailLabel" Text="Waveform"/>
                  <controls:WaveMemoryEditorControl Grid.Row="1"
                                                    DataHex="{Binding DataHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    DataHexEdited="OnWaveMemoryDataHexEdited"
                                                    Height="132"/>
                </Grid>
              </Grid>
            </Border>

            <TextBlock Grid.Row="4"
                       Margin="0,8,0,0"
                       Text="{Binding WaveMemoryStatus}"
                       FontFamily="Consolas"
                       FontSize="11"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                       Opacity="0.8"
                       TextTrimming="CharacterEllipsis"/>
          </Grid>
        </Border>
      </TabItem>

      <TabItem Classes="hiddenNav">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Classes="sideNavIcon" Data="M19.07 4.92999C20.9447 6.80527 21.9979 9.34835 21.9979 12C21.9979 14.6516 20.9447 17.1947 19.07 19.07M15.54 8.45999C16.4774 9.39763 17.0039 10.6692 17.0039 11.995C17.0039 13.3208 16.4774 14.5924 15.54 15.53M11 4.99999L6 8.99999H2V15H6L11 19V4.99999Z"/>
            </Viewbox>
            <TextBlock Text="Voice" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>
        </TabItem.Header>
        <Border Padding="0" Background="{DynamicResource AppWindowBackgroundBrush}">
          <Border.Styles>
            <Style Selector="TextBlock.voiceDataText">
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style Selector="TextBox.voiceDataCell">
              <Setter Property="Height" Value="18"/>
              <Setter Property="MinHeight" Value="18"/>
              <Setter Property="MaxHeight" Value="18"/>
              <Setter Property="Padding" Value="4,0"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="CornerRadius" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="ClipToBounds" Value="True"/>
            </Style>
            <Style Selector="ListBox.voiceDataList">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Padding" Value="0"/>
            </Style>
            <Style Selector="ListBox.voiceDataList ListBoxItem">
              <Setter Property="Height" Value="24"/>
              <Setter Property="MinHeight" Value="24"/>
              <Setter Property="Width" Value="984"/>
              <Setter Property="HorizontalAlignment" Value="Left"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            </Style>
            <Style Selector="ListBox.voiceDataList ListBoxItem:selected">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="ListBox.voiceDataList ListBoxItem:pointerover">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
          </Border.Styles>

          <Border.Resources>
            <DataTemplate x:Key="VoiceDataRowTemplate" x:DataType="vm:WaveDataRow">
              <Border Height="24"
                      Width="984"
                      HorizontalAlignment="Left"
                      Background="{Binding RowBackground}"
                      ClipToBounds="True"
                      PointerEntered="OnTableRowPointerEntered"
                      PointerExited="OnTableRowPointerExited"
                      PointerPressed="OnWaveDataRowPointerPressed">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Insert Above" Click="OnWaveDataRowInsertAboveClicked"/>
                    <MenuItem Header="Insert Below" Click="OnWaveDataRowInsertBelowClicked"/>
                    <MenuItem Header="Copy Row" Click="OnWaveDataRowCopyClicked"/>
                    <MenuItem Header="Paste Below" Click="OnWaveDataRowPasteClicked"/>
                    <Separator/>
                    <MenuItem Header="Delete" Click="OnWaveDataRowDeleteClicked"/>
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid ColumnDefinitions="48,120,150,80,48,62,62,220,150,44">
                  <Border Grid.Column="0" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBlock Classes="voiceDataText" Text="{Binding IdText}" HorizontalAlignment="Center"/>
                  </Border>
                  <Border Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceDataCell" Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  </Border>
                  <Border Grid.Column="2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBlock Classes="voiceDataText"
                               Text="{Binding FileDisplay}"
                               TextTrimming="CharacterEllipsis"
                               Margin="8,0,4,0"/>
                  </Border>
                  <Border Grid.Column="3" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBlock Classes="voiceDataText"
                               Text="{Binding FrequencyText}"
                               TextTrimming="CharacterEllipsis"
                               Margin="8,0,4,0"/>
                  </Border>
                  <Border Grid.Column="4" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <CheckBox IsChecked="{Binding Loops, Mode=TwoWay}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                  </Border>
                  <Border Grid.Column="5" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceDataCell"
                             Text="{Binding LoopStartText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             HorizontalContentAlignment="Center"/>
                  </Border>
                  <Border Grid.Column="6" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceDataCell"
                             Text="{Binding LoopEndText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             HorizontalContentAlignment="Center"/>
                  </Border>
                  <Border Grid.Column="7" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True" Padding="4,2">
                    <controls:WaveDataEditorControl DataHex="{Binding DataHex}"
                                                    LoopStart="{Binding LoopStart}"
                                                    LoopEnd="{Binding LoopEnd}"
                                                    IsLooping="{Binding Loops}"
                                                    IsEditable="False"
                                                    IsHitTestVisible="False"/>
                  </Border>
                  <Border Grid.Column="8" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="voiceDataCell" Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  </Border>
                  <Border Grid.Column="9">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="2">
                      <Button Classes="voiceTableIconButton" Click="OnWaveDataRowDeleteClicked">
                        <Viewbox Width="13" Height="13">
                  <Canvas Width="16" Height="16">
                    <Path Classes="voiceTableMutedIconPath"
                          Data="M9.75 6.25L6.25 9.75M6.25 6.25L9.75 9.75M13 8C13 10.7614 10.7614 13 8 13C5.23858 13 3 10.7614 3 8C3 5.23858 5.23858 3 8 3C10.7614 3 13 5.23858 13 8Z"/>
                  </Canvas>
                </Viewbox>
                      </Button>
                      <Button Classes="voiceTableIconButton" Click="OnWaveDataRowMoreClicked">
                        <Viewbox Width="14" Height="14">
                          <Canvas Width="16" Height="16">
                            <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 8.66667C8.3682 8.66667 8.66668 8.36819 8.66668 8.00001C8.66668 7.63182 8.3682 7.33334 8.00001 7.33334C7.63182 7.33334 7.33334 7.63182 7.33334 8.00001C7.33334 8.36819 7.63182 8.66667 8.00001 8.66667Z"/>
                            <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 4C8.3682 4 8.66668 3.70153 8.66668 3.33334C8.66668 2.96515 8.3682 2.66667 8.00001 2.66667C7.63182 2.66667 7.33334 2.96515 7.33334 3.33334C7.33334 3.70153 7.63182 4 8.00001 4Z"/>
                            <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 13.3333C8.3682 13.3333 8.66668 13.0349 8.66668 12.6667C8.66668 12.2985 8.3682 12 8.00001 12C7.63182 12 7.33334 12.2985 7.33334 12.6667C7.33334 13.0349 7.63182 13.3333 8.00001 13.3333Z"/>
                          </Canvas>
                        </Viewbox>
                      </Button>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </Border.Resources>

          <Grid Width="1004" HorizontalAlignment="Left" RowDefinitions="32,*,20,196,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="0,5,20,5"
                          HorizontalAlignment="Right">
                <Button Classes="voiceTableIconButton" Click="OnWaveDataInsertBelowSelectedClicked">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M9.99996 6.66667V13.3333M6.66663 10H13.3333M18.3333 10C18.3333 14.6024 14.6023 18.3333 9.99996 18.3333C5.39759 18.3333 1.66663 14.6024 1.66663 10C1.66663 5.39763 5.39759 1.66667 9.99996 1.66667C14.6023 1.66667 18.3333 5.39763 18.3333 10Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedWaveData}" Click="OnWaveDataDuplicateSelectedClicked">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M4.16663 12.5H3.33329C2.89127 12.5 2.46734 12.3244 2.15478 12.0118C1.84222 11.6993 1.66663 11.2754 1.66663 10.8333V3.33333C1.66663 2.89131 1.84222 2.46738 2.15478 2.15482C2.46734 1.84226 2.89127 1.66667 3.33329 1.66667H10.8333C11.2753 1.66667 11.6992 1.84226 12.0118 2.15482C12.3244 2.46738 12.5 2.89131 12.5 3.33333V4.16667M9.16663 7.5H16.6666C17.5871 7.5 18.3333 8.24619 18.3333 9.16667V16.6667C18.3333 17.5871 17.5871 18.3333 16.6666 18.3333H9.16663C8.24615 18.3333 7.49996 17.5871 7.49996 16.6667V9.16667C7.49996 8.24619 8.24615 7.5 9.16663 7.5Z"/>
                  </Viewbox>
                </Button>
                <Button Classes="voiceTableIconButton" IsEnabled="{Binding CanEditSelectedWaveData}" Click="OnWaveDataDeleteSelectedClicked">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="voiceTableIconPath" Data="M2.5 5H4.16667M4.16667 5H17.5M4.16667 5L4.16667 16.6667C4.16667 17.1087 4.34226 17.5326 4.65482 17.8452C4.96738 18.1577 5.39131 18.3333 5.83333 18.3333H14.1667C14.6087 18.3333 15.0326 18.1577 15.3452 17.8452C15.6577 17.5326 15.8333 17.1087 15.8333 16.6667V5M6.66667 5V3.33333C6.66667 2.89131 6.84226 2.46738 7.15482 2.15482C7.46738 1.84226 7.89131 1.66667 8.33333 1.66667H11.6667C12.1087 1.66667 12.5326 1.84226 12.8452 2.15482C13.1577 2.46738 13.3333 2.89131 13.3333 3.33333V5M8.33333 9.16667V14.1667M11.6667 9.16667V14.1667"/>
                  </Viewbox>
                </Button>
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Width="1004" HorizontalAlignment="Left" RowDefinitions="22,*">
              <Grid Height="22"
                    Grid.Row="0"
                    Width="984"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource AppControlBackgroundBrush}"
                    ColumnDefinitions="48,120,150,80,48,62,62,220,150,44">
                <TextBlock Grid.Column="0" Classes="voiceDataText" Text="Index" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Classes="voiceDataText" Text="Label" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="2" Classes="voiceDataText" Text="File" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="3" Classes="voiceDataText" Text="Freq" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="4" Classes="voiceDataText" Text="Loop" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Classes="voiceDataText" Text="Start" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="6" Classes="voiceDataText" Text="End" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="7" Classes="voiceDataText" Text="Waveform" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="8" Classes="voiceDataText" Text="Note" Margin="8,0,0,0"/>
              </Grid>
              <ListBox Grid.Row="1"
                       Classes="voiceDataList"
                       ItemsSource="{Binding WaveDataRows}"
                       SelectedItem="{Binding SelectedWaveData, Mode=TwoWay}"
                       ItemTemplate="{StaticResource VoiceDataRowTemplate}"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
              </ListBox>
            </Grid>

            <Button Grid.Row="2"
                    Classes="voiceTableIconButton"
                    HorizontalAlignment="Center"
                    Click="OnWaveDataAddEndClicked">
              <Viewbox Width="15" Height="15">
                <Path Classes="voiceTableIconPath"
                      Data="M9.99996 6.66667V13.3333M6.66663 10H13.3333M18.3333 10C18.3333 14.6024 14.6023 18.3333 9.99996 18.3333C5.39759 18.3333 1.66663 14.6024 1.66663 10C1.66663 5.39763 5.39759 1.66667 9.99996 1.66667C14.6023 1.66667 18.3333 5.39763 18.3333 10Z"/>
              </Viewbox>
            </Button>

            <Border Grid.Row="3"
                    Margin="0,10,20,0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    CornerRadius="6"
                    Padding="16"
                    DataContext="{Binding SelectedWaveData}">
              <Grid ColumnDefinitions="260,170,*" RowDefinitions="Auto,*" ColumnSpacing="18" RowSpacing="8">
                <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="64,*" RowSpacing="6">
                  <TextBlock Grid.Row="0" Grid.Column="0" Classes="voiceDetailLabel" Text="Index"/>
                  <TextBox Grid.Row="0" Grid.Column="1" Classes="voiceDetailField" Text="{Binding IdText}" IsReadOnly="True" IsHitTestVisible="False"/>
                  <TextBlock Grid.Row="1" Grid.Column="0" Classes="voiceDetailLabel" Text="Label"/>
                  <TextBox Grid.Row="1" Grid.Column="1" Classes="voiceDetailField" Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  <TextBlock Grid.Row="2" Grid.Column="0" Classes="voiceDetailLabel" Text="File"/>
                  <TextBox Grid.Row="2" Grid.Column="1" Classes="voiceDetailField" Text="{Binding FileDisplay}" IsReadOnly="True" IsHitTestVisible="False"/>
                  <TextBlock Grid.Row="3" Grid.Column="0" Classes="voiceDetailLabel" Text="Freq"/>
                  <TextBox Grid.Row="3" Grid.Column="1" Classes="voiceDetailField" Text="{Binding FrequencyText}" IsReadOnly="True" IsHitTestVisible="False"/>
                  <TextBlock Grid.Row="4" Grid.Column="0" Classes="voiceDetailLabel" Text="Samples"/>
                  <TextBox Grid.Row="4" Grid.Column="1" Classes="voiceDetailField" Text="{Binding SampleCountText}" IsReadOnly="True" IsHitTestVisible="False"/>
                </Grid>

                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="70,*" RowSpacing="7">
                  <TextBlock Grid.Row="0" Grid.Column="0" Classes="voiceDetailLabel" Text="Loop"/>
                  <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding Loops, Mode=TwoWay}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Row="1" Grid.Column="0" Classes="voiceDetailLabel" Text="Start"/>
                  <TextBox Grid.Row="1" Grid.Column="1" Classes="voiceDetailField" Text="{Binding LoopStartText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  <TextBlock Grid.Row="2" Grid.Column="0" Classes="voiceDetailLabel" Text="End"/>
                  <TextBox Grid.Row="2" Grid.Column="1" Classes="voiceDetailField" Text="{Binding LoopEndText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  <TextBlock Grid.Row="3" Grid.Column="0" Classes="voiceDetailLabel" Text="Note"/>
                  <TextBox Grid.Row="3" Grid.Column="1" Classes="voiceDetailField" Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Grid Grid.Column="2" RowDefinitions="Auto,*" RowSpacing="6">
                  <TextBlock Grid.Row="0" Classes="voiceDetailLabel" Text="Waveform / Loop Points"/>
                  <controls:WaveDataEditorControl Grid.Row="1"
                                                  DataHex="{Binding DataHex}"
                                                  LoopStart="{Binding LoopStart, Mode=TwoWay}"
                                                  LoopEnd="{Binding LoopEnd, Mode=TwoWay}"
                                                  IsLooping="{Binding Loops, Mode=TwoWay}"
                                                  LoopPointsEdited="OnWaveDataLoopPointsEdited"
                                                  Height="132"/>
                </Grid>
              </Grid>
            </Border>

            <TextBlock Grid.Row="4"
                       Margin="0,8,0,0"
                       Text="{Binding VoiceStatus}"
                       FontFamily="Consolas"
                       FontSize="11"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                       Opacity="0.8"
                       TextTrimming="CharacterEllipsis"/>
          </Grid>
        </Border>
      </TabItem>

      <TabItem Classes="hiddenNav">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Classes="sideNavIcon" Data="M5 10V12C5 13.8565 5.7375 15.637 7.05025 16.9497C8.36301 18.2625 10.1435 19 12 19C13.8565 19 15.637 18.2625 16.9497 16.9497C18.2625 15.637 19 13.8565 19 12V10M12 19V23M8 23H16M12 1C11.2044 1 10.4413 1.31607 9.87868 1.87868C9.31607 2.44129 9 3.20435 9 4V12C9 12.7956 9.31607 13.5587 9.87868 14.1213C10.4413 14.6839 11.2044 15 12 15C12.7956 15 13.5587 14.6839 14.1213 14.1213C14.6839 13.5587 15 12.7956 15 12V4C15 3.20435 14.6839 2.44129 14.1213 1.87868C13.5587 1.31607 12.7956 1 12 1Z"/>
            </Viewbox>
            <TextBlock Text="Cry Editor" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>
        </TabItem.Header>
        <Border Padding="24" Background="{DynamicResource AppWindowBackgroundBrush}">
          <TextBlock Text="Cry Editor editor is not implemented yet."
                     FontFamily="Consolas"
                     FontSize="12"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
        </Border>
      </TabItem>
      <TabItem Classes="hiddenNav">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Classes="sideNavIcon" Data="M9.24995 22L8.84995 18.8C8.63328 18.7167 8.42912 18.6167 8.23745 18.5C8.04578 18.3833 7.85828 18.2583 7.67495 18.125L4.69995 19.375L1.94995 14.625L4.52495 12.675C4.50828 12.5583 4.49995 12.4458 4.49995 12.3375V11.6625C4.49995 11.5542 4.50828 11.4417 4.52495 11.325L1.94995 9.375L4.69995 4.625L7.67495 5.875C7.85828 5.74167 8.04995 5.61667 8.24995 5.5C8.44995 5.38333 8.64995 5.28333 8.84995 5.2L9.24995 2H14.75L15.15 5.2C15.3666 5.28333 15.5708 5.38333 15.7625 5.5C15.9541 5.61667 16.1416 5.74167 16.325 5.875L19.3 4.625L22.05 9.375L19.475 11.325C19.4916 11.4417 19.5 11.5542 19.5 11.6625V12.3375C19.5 12.4458 19.4833 12.5583 19.45 12.675L22.025 14.625L19.275 19.375L16.325 18.125C16.1416 18.2583 15.95 18.3833 15.75 18.5C15.55 18.6167 15.35 18.7167 15.15 18.8L14.75 22H9.24995Z"/>
            </Viewbox>
            <TextBlock Text="Settings" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>
        </TabItem.Header>
        <views:SettingsView x:Name="SettingsPage"/>
      </TabItem>
      <TabItem Classes="hiddenNav" IsVisible="False">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Classes="sideNavIcon" Data="M16.6667 6.66669L11.6667 1.66669H5.00001C4.55798 1.66669 4.13406 1.84228 3.8215 2.15484C3.50894 2.4674 3.33334 2.89133 3.33334 3.33335V16.6667C3.33334 17.1087 3.50894 17.5326 3.8215 17.8452C4.13406 18.1578 4.55798 18.3334 5.00001 18.3334H15C15.442 18.3334 15.866 18.1578 16.1785 17.8452C16.4911 17.5326 16.6667 17.1087 16.6667 16.6667V6.66669ZM11.6667 1.66669L11.6667 6.66669H16.6667M10 15V10M7.50001 12.5H12.5"/>
            </Viewbox>
            <TextBlock Text="ROM" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>
        </TabItem.Header>
        <Border Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding RomStatus}"
                       FontFamily="Consolas"
                       FontSize="12" />
            <TextBlock Text="MP2K discovery and song-table parsing will start here."
                       FontFamily="Consolas"
                       FontSize="12"
                       Opacity="0.75" />
          </StackPanel>
        </Border>
      </TabItem>

      </TabControl>
    </Grid>

    <Grid Grid.Row="2" RowDefinitions="Auto,78">
      <Border x:Name="PreviewKeyboardHost"
              Grid.Row="0"
              IsVisible="False"
              Background="{DynamicResource AppSurfaceBrush}"
              BorderBrush="{DynamicResource AppControlPressedBrush}"
              BorderThickness="0,1,0,0"
              Padding="8,6">
        <controls:PianoKeyboard x:Name="Piano"
                                MinNote="0"
                                MaxNote="127"
                                Height="104"
                                HighlightedNotes="{Binding SelectedVoiceKeyMarkers}"
                                MappedNotes="{Binding SelectedDrumSetKeyMarkers}"
                                ActiveNoteChannelMasks="{Binding ActiveNoteChannelMasks}"
                                KeySplitKeyMapHex="{Binding SelectedKeySplitKeyMapHex, Mode=TwoWay}"
                                KeySplitRegionLabels="{Binding KeySplitRangeLabels}"
                                SelectedKeySplitRegionIndex="{Binding SelectedKeySplitRegionIndex, Mode=TwoWay}"/>
      </Border>

      <Grid Grid.Row="1"
            RowDefinitions="3,*"
            Background="{DynamicResource AppControlPressedBrush}">
        <ProgressBar Grid.Row="0"
                     Minimum="0"
                     Maximum="100"
                     Value="{Binding PlaybackProgress}"
                     IsHitTestVisible="False"
                     Foreground="#405BFF"
                     Background="{DynamicResource AppTextMutedBrush}"
                     BorderThickness="0"/>

        <Grid Grid.Row="1"
              ColumnDefinitions="240,*,260"
              Margin="20,8,24,10">
          <StackPanel Grid.Column="0"
                      Spacing="6"
                      VerticalAlignment="Center">
            <ComboBox ItemsSource="{Binding Sequences}"
                      SelectedItem="{Binding SelectedSequence, Mode=TwoWay}"
                      Classes="playAreaSelect">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:SequenceHeaderRow">
                  <TextBlock Text="{Binding Display}"
                             FontFamily="Consolas"
                             FontSize="11"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <ComboBox ItemsSource="{Binding VoiceGroupOptions}"
                      SelectedItem="{Binding SelectedVoiceGroup, Mode=TwoWay}"
                      Classes="playAreaSelect">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:VoiceGroupOption">
                  <TextBlock Text="{Binding Display}"
                             FontFamily="Consolas"
                             FontSize="11"
                             TextTrimming="CharacterEllipsis"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="12">
            <Button Classes="playAreaIcon"
                    ToolTip.Tip="MIDI Reset"
                    Click="OnPlayAreaMidiResetClicked">
              <Viewbox Width="16" Height="16">
                <Path Classes="playAreaIconPath" Data="M5.83331 8.33331H0.833313V3.33331M0.833313 8.33331L4.69998 4.69998C5.5956 3.80391 6.70362 3.14932 7.92065 2.79729C9.13768 2.44527 10.4241 2.40727 11.6597 2.68686C12.8954 2.96645 14.0401 3.55451 14.9871 4.39616C15.934 5.23782 16.6523 6.30564 17.075 7.49998M14.1666 11.6666H19.1666V16.6666M19.1666 11.6666L15.3 15.3C14.4044 16.1961 13.2963 16.8506 12.0793 17.2027C10.8623 17.5547 9.5759 17.5927 8.34022 17.3131C7.10453 17.0335 5.95981 16.4455 5.01287 15.6038C4.06592 14.7621 3.34762 13.6943 2.92498 12.5"/>
              </Viewbox>
            </Button>
            <Button Classes="playAreaIcon"
                    ToolTip.Tip="Previous Song"
                    Click="OnPlayAreaPreviousClicked">
              <Viewbox Width="18" Height="18">
                <Path Fill="{DynamicResource AppTextPrimaryBrush}" Data="M4 4H6V20H4V4ZM8 12L20 4V20L8 12Z"/>
              </Viewbox>
            </Button>
            <Button Classes="playAreaIcon"
                    Width="42"
                    Height="42"
                    MinWidth="42"
                    MinHeight="42"
                    ToolTip.Tip="Play / Stop"
                    Click="OnPlayAreaPlayStopClicked">
              <Viewbox Width="24" Height="24">
                <Path Fill="{DynamicResource AppTextPrimaryBrush}" Data="M8 5V19L19 12L8 5Z"/>
              </Viewbox>
            </Button>
            <Button Classes="playAreaIcon"
                    ToolTip.Tip="Next Song"
                    Click="OnPlayAreaNextClicked">
              <Viewbox Width="18" Height="18">
                <Path Fill="{DynamicResource AppTextPrimaryBrush}" Data="M18 4H20V20H18V4ZM4 4L16 12L4 20V4Z"/>
              </Viewbox>
            </Button>
          </StackPanel>

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Spacing="10">
            <Button x:Name="PlayAreaRecordButton"
                    Classes="playAreaIcon"
                    ToolTip.Tip="Record"
                    Click="OnPlayAreaRecordClicked">
              <Ellipse Width="14"
                       Height="14"
                       Fill="{DynamicResource AppTextPrimaryBrush}"/>
            </Button>
            <Button Classes="playAreaIcon"
                    ToolTip.Tip="Mute"
                    Click="OnPlayAreaMuteClicked">
              <Viewbox Width="17" Height="17">
                <Path Classes="playAreaIconPath" Data="M19.07 4.92999C20.9447 6.80527 21.9979 9.34835 21.9979 12C21.9979 14.6516 20.9447 17.1947 19.07 19.07M15.54 8.45999C16.4774 9.39763 17.0039 10.6692 17.0039 11.995C17.0039 13.3208 16.4774 14.5924 15.54 15.53M11 4.99999L6 8.99999H2V15H6L11 19V4.99999Z"/>
              </Viewbox>
            </Button>
            <Slider Width="140"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding MasterVolume, Mode=TwoWay}"
                    VerticalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
  </Border>
</Window>

