      </Border>

      <TabControl x:Name="MainTabs" Grid.Column="1" TabStripPlacement="Left" Classes="sideNavTabs" SelectionChanged="OnMainTabsSelectionChanged">
      <TabItem Classes="hiddenNav">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Classes="sideNavIcon" Data="M4 21V14M4 10V3M12 21V12M12 8V3M20 21V16M20 12V3M1 14H7M9 8H15M17 16H23"/>
            </Viewbox>
            <TextBlock Text="Mixer" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>
        </TabItem.Header>
        <mixerViews:MixerView/>
      </TabItem>

      <TabItem Classes="hiddenNav">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
              <Path Classes="sideNavIcon" Data="M9 18V5L21 3V16M9 18C9 19.6569 7.65685 21 6 21C4.34315 21 3 19.6569 3 18C3 16.3431 4.34315 15 6 15C7.65685 15 9 16.3431 9 18ZM21 16C21 17.6569 19.6569 19 18 19C16.3431 19 15 17.6569 15 16C15 14.3431 16.3431 13 18 13C19.6569 13 21 14.3431 21 16Z"/>
            </Viewbox>
            <TextBlock Text="Song Table" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>
        </TabItem.Header>
        <Border Padding="0" Background="{DynamicResource AppWindowBackgroundBrush}">
          <Border.Styles>
            <Style Selector="TextBlock.songTableText">
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style Selector="TextBox.songTableCell">
              <Setter Property="Height" Value="18"/>
              <Setter Property="MinHeight" Value="18"/>
              <Setter Property="MaxHeight" Value="18"/>
              <Setter Property="Padding" Value="4,0"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="CornerRadius" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="ClipToBounds" Value="True"/>
            </Style>
            <Style Selector="TextBox.songTableNumberCell">
              <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>
            <Style Selector="ComboBox.songTableCombo">
              <Setter Property="Height" Value="20"/>
              <Setter Property="MinHeight" Value="20"/>
              <Setter Property="Padding" Value="4,0"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="CornerRadius" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
              <Setter Property="FontFamily" Value="Consolas"/>
              <Setter Property="FontSize" Value="10"/>
            </Style>
            <Style Selector="Button.songTableIconButton">
              <Setter Property="Width" Value="20"/>
              <Setter Property="Height" Value="20"/>
              <Setter Property="MinWidth" Value="20"/>
              <Setter Property="MinHeight" Value="20"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
              <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
              <Setter Property="FontSize" Value="13"/>
              <Setter Property="HorizontalContentAlignment" Value="Center"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style Selector="Button.songTableIconButton:pointerover">
              <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}"/>
            </Style>
            <Style Selector="Button.songTableIconButton:pressed">
              <Setter Property="Background" Value="{DynamicResource AppControlPressedBrush}"/>
            </Style>
            <Style Selector="Button.songTableIconButton:disabled">
              <Setter Property="Opacity" Value="0.28"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
            <Style Selector="Path.songTableIconPath">
              <Setter Property="Stroke" Value="{DynamicResource AppTextSecondaryBrush}"/>
              <Setter Property="StrokeThickness" Value="2"/>
              <Setter Property="StrokeLineCap" Value="Round"/>
              <Setter Property="StrokeJoin" Value="Round"/>
            </Style>
            <Style Selector="Path.songTableMutedIconPath">
              <Setter Property="Stroke" Value="{DynamicResource AppTextMutedBrush}"/>
              <Setter Property="StrokeThickness" Value="1.6"/>
              <Setter Property="StrokeLineCap" Value="Round"/>
              <Setter Property="StrokeJoin" Value="Round"/>
            </Style>
            <Style Selector="ListBox.songTableList">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Padding" Value="0"/>
            </Style>
            <Style Selector="ListBox.songTableList ListBoxItem">
              <Setter Property="Height" Value="20"/>
              <Setter Property="MinHeight" Value="20"/>
              <Setter Property="Width" Value="984"/>
              <Setter Property="HorizontalAlignment" Value="Left"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            </Style>
            <Style Selector="ListBox.songTableList ListBoxItem:selected">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="ListBox.songTableList ListBoxItem:pointerover">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
          </Border.Styles>

          <Border.Resources>
            <DataTemplate x:Key="SongTableRowTemplate" x:DataType="vm:SongTableEntryRow">
              <Border Height="20"
                      Width="984"
                      HorizontalAlignment="Left"
                      Background="{Binding RowBackground}"
                      ClipToBounds="True"
                      PointerEntered="OnTableRowPointerEntered"
                      PointerExited="OnTableRowPointerExited"
                      PointerPressed="OnSongTableRowPointerPressed"
                      DragDrop.AllowDrop="True"
                      DragDrop.Drop="OnSongTableRowDrop">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Move Up" Click="OnSongTableRowMoveUpClicked"/>
                    <MenuItem Header="Move Down" Click="OnSongTableRowMoveDownClicked"/>
                    <Separator/>
                    <MenuItem Header="Insert Above" Click="OnSongTableRowInsertAboveClicked"/>
                    <MenuItem Header="Insert Below" Click="OnSongTableRowInsertBelowClicked"/>
                    <MenuItem Header="Copy Row" Click="OnSongTableRowCopyClicked"/>
                    <MenuItem Header="Paste Below" Click="OnSongTableRowPasteClicked"/>
                    <Separator/>
                    <MenuItem Header="Delete" Click="OnSongTableRowDeleteClicked"/>
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid ColumnDefinitions="16,48,135,285,48,48,360,44">
                  <Border Grid.Column="0"
                          Background="{DynamicResource AppTableHoverBrush}"
                          PointerPressed="OnSongTableDragHandlePointerPressed"
                          Cursor="SizeAll">
                    <Viewbox Width="12" Height="12"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                      <Canvas Width="16" Height="16">
                        <Path Classes="songTableIconPath" StrokeThickness="1.6" Data="M8.00001 8.66667C8.3682 8.66667 8.66668 8.36819 8.66668 8.00001C8.66668 7.63182 8.3682 7.33334 8.00001 7.33334C7.63182 7.33334 7.33334 7.63182 7.33334 8.00001C7.33334 8.36819 7.63182 8.66667 8.00001 8.66667Z"/>
                        <Path Classes="songTableIconPath" StrokeThickness="1.6" Data="M8.00001 4C8.3682 4 8.66668 3.70153 8.66668 3.33334C8.66668 2.96515 8.3682 2.66667 8.00001 2.66667C7.63182 2.66667 7.33334 2.96515 7.33334 3.33334C7.33334 3.70153 7.63182 4 8.00001 4Z"/>
                        <Path Classes="songTableIconPath" StrokeThickness="1.6" Data="M8.00001 13.3333C8.3682 13.3333 8.66668 13.0349 8.66668 12.6667C8.66668 12.2985 8.3682 12 8.00001 12C7.63182 12 7.33334 12.2985 7.33334 12.6667C7.33334 13.0349 7.63182 13.3333 8.00001 13.3333Z"/>
                      </Canvas>
                    </Viewbox>
                  </Border>
                  <Border Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBlock Classes="songTableText"
                               Text="{Binding IndexText}"
                               HorizontalAlignment="Center"/>
                  </Border>
                  <Border Grid.Column="2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="songTableCell" Text="{Binding Label, Mode=TwoWay}"/>
                  </Border>
                  <Border Grid.Column="3" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <Grid ColumnDefinitions="*,28">
                      <TextBlock Grid.Column="0"
                                 Classes="songTableText"
                                 Text="{Binding SongHeaderDisplay}"
                                 TextTrimming="CharacterEllipsis"
                                 Margin="8,0,4,0"
                                 VerticalAlignment="Center"/>
                      <Button Grid.Column="1"
                              Classes="songTableIconButton"
                              Click="OnSongTableSelectHeaderClicked"/>
                    </Grid>
                  </Border>
                  <Border Grid.Column="4" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="songTableCell songTableNumberCell"
                             Text="{Binding Group1Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="OnSongTableNumberTextChanged"/>
                  </Border>
                  <Border Grid.Column="5" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="songTableCell songTableNumberCell"
                             Text="{Binding Group2Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="OnSongTableNumberTextChanged"/>
                  </Border>
                  <Border Grid.Column="6" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <TextBox Classes="songTableCell" Text="{Binding Note, Mode=TwoWay}"/>
                  </Border>
                  <Border Grid.Column="7">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="2">
                      <Button Classes="songTableIconButton"
                              FontSize="14"
                              Click="OnSongTableRowDeleteClicked">
                        <Viewbox Width="13" Height="13">
                  <Canvas Width="16" Height="16">
                    <Path Classes="songTableMutedIconPath"
                          Data="M9.75 6.25L6.25 9.75M6.25 6.25L9.75 9.75M13 8C13 10.7614 10.7614 13 8 13C5.23858 13 3 10.7614 3 8C3 5.23858 5.23858 3 8 3C10.7614 3 13 5.23858 13 8Z"/>
                  </Canvas>
                </Viewbox>
                      </Button>
                      <Button Classes="songTableIconButton"
                              Click="OnSongTableRowMoreClicked">
                        <Viewbox Width="14" Height="14">
                          <Canvas Width="16" Height="16">
                            <Path Classes="songTableIconPath" StrokeThickness="1.6" Data="M8.00001 8.66667C8.3682 8.66667 8.66668 8.36819 8.66668 8.00001C8.66668 7.63182 8.3682 7.33334 8.00001 7.33334C7.63182 7.33334 7.33334 7.63182 7.33334 8.00001C7.33334 8.36819 7.63182 8.66667 8.00001 8.66667Z"/>
                            <Path Classes="songTableIconPath" StrokeThickness="1.6" Data="M8.00001 4C8.3682 4 8.66668 3.70153 8.66668 3.33334C8.66668 2.96515 8.3682 2.66667 8.00001 2.66667C7.63182 2.66667 7.33334 2.96515 7.33334 3.33334C7.33334 3.70153 7.63182 4 8.00001 4Z"/>
                            <Path Classes="songTableIconPath" StrokeThickness="1.6" Data="M8.00001 13.3333C8.3682 13.3333 8.66668 13.0349 8.66668 12.6667C8.66668 12.2985 8.3682 12 8.00001 12C7.63182 12 7.33334 12.2985 7.33334 12.6667C7.33334 13.0349 7.63182 13.3333 8.00001 13.3333Z"/>
                          </Canvas>
                        </Viewbox>
                      </Button>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </Border.Resources>

          <Grid Width="1004" HorizontalAlignment="Left" RowDefinitions="32,*,20,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,0">
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="0,5,20,5"
                          HorizontalAlignment="Right">
                <Button Classes="songTableIconButton" IsEnabled="{Binding CanEditSelectedSongTableEntry}" Click="OnSongTableMoveSelectedUpClicked">
                  <Viewbox Width="15" Height="15">
                    <Path Classes="songTableIconPath" Data="M9.99996 15.8333V4.16666M15.8333 10L9.99996 4.16666L4.16663 10"/>
                  </Viewbox>
                </Button>
                <Button Classes="songTableIconButton" IsEnabled="{Binding CanEditSelectedSongTableEntry}" Click="OnSongTableMoveSelectedDownClicked">
