            </Viewbox>
          </Button>
          <Button Classes="titleBarIcon"
                  ToolTip.Tip="Minimize"
                  Click="OnMinimizeClicked">
            <Viewbox Width="14" Height="14">
              <Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="1.7" StrokeLineCap="Round" Data="M3 11H17"/>
            </Viewbox>
          </Button>
          <Button Classes="titleBarIcon"
                  ToolTip.Tip="Maximize"
                  Click="OnMaximizeRestoreClicked">
            <Border Width="10" Height="10" BorderBrush="{DynamicResource AppTextSecondaryBrush}" BorderThickness="1.4"/>
          </Button>
          <Button Classes="titleBarIcon windowClose"
                  ToolTip.Tip="Close"
                  Click="OnCloseClicked">
            <Viewbox Width="12" Height="12">
              <Path Stroke="{DynamicResource AppTextSecondaryBrush}" StrokeThickness="1.8" StrokeLineCap="Round" Data="M4 4L16 16M16 4L4 16"/>
            </Viewbox>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

