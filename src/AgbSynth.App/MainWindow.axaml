  <Border Background="{DynamicResource AppSurfaceAltBrush}"
          CornerRadius="14"
          ClipToBounds="True">
  <Grid RowDefinitions="Auto,*,Auto"
        Background="{DynamicResource AppSurfaceAltBrush}">
    <Border Grid.Row="0"
            x:Name="TitleBar"
            Height="34"
            Padding="14,0,4,0"
            Background="{DynamicResource AppWindowBackgroundBrush}"
            PointerPressed="OnTitleBarPointerPressed">
      <Grid>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">
          <Button Classes="titleBarIcon" ToolTip.Tip="New Project" Click="OnNewProjectClicked">
            <Viewbox Width="15" Height="15">
              <Path Classes="titleIconPath" Data="M16.6667 6.66669L11.6667 1.66669H5.00001C4.55798 1.66669 4.13406 1.84228 3.8215 2.15484C3.50894 2.4674 3.33334 2.89133 3.33334 3.33335V16.6667C3.33334 17.1087 3.50894 17.5326 3.8215 17.8452C4.13406 18.1578 4.55798 18.3334 5.00001 18.3334H15C15.442 18.3334 15.866 18.1578 16.1785 17.8452C16.4911 17.5326 16.6667 17.1087 16.6667 16.6667V6.66669ZM11.6667 1.66669L11.6667 6.66669H16.6667M10 15V10M7.50001 12.5H12.5"/>
            </Viewbox>
          </Button>
          <Button Classes="titleBarIcon" ToolTip.Tip="Open Project" Click="OnOpenProjectClicked">
            <Viewbox Width="15" Height="15">
              <Path Classes="titleIconPath" Data="M18.3333 15.8333C18.3333 16.2754 18.1577 16.6993 17.8452 17.0118C17.5326 17.3244 17.1087 17.5 16.6667 17.5H3.33332C2.8913 17.5 2.46737 17.3244 2.15481 17.0118C1.84225 16.6993 1.66666 16.2754 1.66666 15.8333V4.16667C1.66666 3.72464 1.84225 3.30072 2.15481 2.98816C2.46737 2.67559 2.8913 2.5 3.33332 2.5H7.49999L9.16666 5H16.6667C17.1087 5 17.5326 5.17559 17.8452 5.48816C18.1577 5.80072 18.3333 6.22464 18.3333 6.66667V15.8333Z"/>
            </Viewbox>
          </Button>
          <Button Classes="titleBarIcon" ToolTip.Tip="Refresh" Click="OnRefreshProjectClicked">
            <Viewbox Width="15" Height="15">
              <Path Classes="titleIconPath" Data="M5.83331 8.33331H0.833313V3.33331M0.833313 8.33331L4.69998 4.69998C5.5956 3.80391 6.70362 3.14932 7.92065 2.79729C9.13768 2.44527 10.4241 2.40727 11.6597 2.68686C12.8954 2.96645 14.0401 3.55451 14.9871 4.39616C15.934 5.23782 16.6523 6.30564 17.075 7.49998M14.1666 11.6666H19.1666V16.6666M19.1666 11.6666L15.3 15.3C14.4044 16.1961 13.2963 16.8506 12.0793 17.2027C10.8623 17.5547 9.5759 17.5927 8.34022 17.3131C7.10453 17.0335 5.95981 16.4455 5.01287 15.6038C4.06592 14.7621 3.34762 13.6943 2.92498 12.5"/>
            </Viewbox>
          </Button>
          <Button Classes="titleBarIcon" ToolTip.Tip="Create Project from ROM" Click="OnOpenRomClicked">
            <Viewbox Width="15" Height="15">
              <Path Classes="titleIconPath" Data="M17.5 12.5V15.8333C17.5 16.2754 17.3244 16.6993 17.0118 17.0118C16.6993 17.3244 16.2754 17.5 15.8333 17.5H4.16667C3.72464 17.5 3.30072 17.3244 2.98816 17.0118C2.67559 16.6993 2.5 16.2754 2.5 15.8333V12.5M14.1667 8.33333L10 12.5L5.83333 8.33333M10 12.5V2.5"/>
            </Viewbox>
          </Button>
          <Button Classes="titleBarIcon" ToolTip.Tip="Compile to ROM">
            <Viewbox Width="15" Height="15">
              <Path Classes="titleIconPath" Data="M17.5 12.5V15.8333C17.5 16.2754 17.3244 16.6993 17.0118 17.0118C16.6993 17.3244 16.2754 17.5 15.8333 17.5H4.16667C3.72464 17.5 3.30072 17.3244 2.98816 17.0118C2.67559 16.6993 2.5 16.2754 2.5 15.8333V12.5M5.83333 6.66667L10 2.5L14.1667 6.66667M10 2.5V12.5"/>
            </Viewbox>
          </Button>
          <Button Classes="titleBarIcon"
                  ToolTip.Tip="Save Project"
                  IsEnabled="{Binding CanSaveProject}"
                  Click="OnSaveProjectClicked">
            <Viewbox Width="15" Height="15">
              <Path Classes="titleIconPath" Data="M14.1667 17.5V10.8333H5.83333V17.5M5.83333 2.5V6.66667H12.5M15.8333 17.5H4.16667C3.72464 17.5 3.30072 17.3244 2.98816 17.0118C2.67559 16.6993 2.5 16.2754 2.5 15.8333V4.16667C2.5 3.72464 2.67559 3.30072 2.98816 2.98816C3.30072 2.67559 3.72464 2.5 4.16667 2.5H13.3333L17.5 6.66667V15.8333C17.5 16.2754 17.3244 16.6993 17.0118 17.0118C16.6993 17.3244 16.2754 17.5 15.8333 17.5Z"/>
            </Viewbox>
          </Button>
          <Button Classes="titleBarIcon"
                  ToolTip.Tip="Undo"
                  IsEnabled="{Binding CanUndoProject}"
                  Click="OnUndoProjectClicked">
            <Viewbox Width="15" Height="15">
              <Path Classes="titleIconPath" Data="M7.49998 3.33331L3.33331 7.49998L7.49998 11.6666M3.33331 7.49998H13.3333C14.2174 7.49998 15.0652 7.85117 15.6903 8.47629C16.3155 9.10141 16.6666 9.94926 16.6666 10.8333V16.6666"/>
            </Viewbox>
          </Button>
          <Button Classes="titleBarIcon"
                  ToolTip.Tip="Redo"
                  IsEnabled="{Binding CanRedoProject}"
                  Click="OnRedoProjectClicked">
            <Viewbox Width="15" Height="15">
              <Path Classes="titleIconPath" Data="M12.5 3.33331L16.6666 7.49998L12.5 11.6666M16.6666 7.49998H6.66665C5.78259 7.49998 4.93474 7.85117 4.30962 8.47629C3.6845 9.10141 3.33331 9.94926 3.33331 10.8333V16.6666"/>
            </Viewbox>
          </Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="0">
          <Button Classes="titleBarIcon"
                  ToolTip.Tip="Settings"
                  Click="OnSettingsClicked">
            <Viewbox Width="16" Height="16">
              <Path Fill="{DynamicResource AppTextSecondaryBrush}" Opacity="0.75" Data="M9.24995 22L8.84995 18.8C8.63328 18.7167 8.42912 18.6167 8.23745 18.5C8.04578 18.3833 7.85828 18.2583 7.67495 18.125L4.69995 19.375L1.94995 14.625L4.52495 12.675C4.50828 12.5583 4.49995 12.4458 4.49995 12.3375V11.6625C4.49995 11.5542 4.50828 11.4417 4.52495 11.325L1.94995 9.375L4.69995 4.625L7.67495 5.875C7.85828 5.74167 8.04995 5.61667 8.24995 5.5C8.44995 5.38333 8.64995 5.28333 8.84995 5.2L9.24995 2H14.75L15.15 5.2C15.3666 5.28333 15.5708 5.38333 15.7625 5.5C15.9541 5.61667 16.1416 5.74167 16.325 5.875L19.3 4.625L22.05 9.375L19.475 11.325C19.4916 11.4417 19.5 11.5542 19.5 11.6625V12.3375C19.5 12.4458 19.4833 12.5583 19.45 12.675L22.025 14.625L19.275 19.375L16.325 18.125C16.1416 18.2583 15.95 18.3833 15.75 18.5C15.55 18.6167 15.35 18.7167 15.15 18.8L14.75 22H9.24995ZM11 20H12.975L13.325 17.35C13.8416 17.2167 14.3208 17.0208 14.7625 16.7625C15.2041 16.5042 15.6083 16.1917 15.975 15.825L18.45 16.85L19.425 15.15L17.275 13.525C17.3583 13.2917 17.4166 13.0458 17.45 12.7875C17.4833 12.5292 17.5 12.2667 17.5 12C17.5 11.7333 17.4833 11.4708 17.45 11.2125C17.4166 10.9542 17.3583 10.7083 17.275 10.475L19.425 8.85L18.45 7.15L15.975 8.2C15.6083 7.81667 15.2041 7.49583 14.7625 7.2375C14.3208 6.97917 13.8416 6.78333 13.325 6.65L13 4H11.025L10.675 6.65C10.1583 6.78333 9.67912 6.97917 9.23745 7.2375C8.79578 7.49583 8.39162 7.80833 8.02495 8.175L5.54995 7.15L4.57495 8.85L6.72495 10.45C6.64162 10.7 6.58328 10.95 6.54995 11.2C6.51662 11.45 6.49995 11.7167 6.49995 12C6.49995 12.2667 6.51662 12.525 6.54995 12.775C6.58328 13.025 6.64162 13.275 6.72495 13.525L4.57495 15.15L5.54995 16.85L8.02495 15.8C8.39162 16.1833 8.79578 16.5042 9.23745 16.7625C9.67912 17.0208 10.1583 17.2167 10.675 17.35L11 20ZM12.05 15.5C13.0166 15.5 13.8416 15.1583 14.525 14.475C15.2083 13.7917 15.55 12.9667 15.55 12C15.55 11.0333 15.2083 10.2083 14.525 9.525C13.8416 8.84167 13.0166 8.5 12.05 8.5C11.0666 8.5 10.2375 8.84167 9.562