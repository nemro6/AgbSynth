<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AgbSynth.App.Controls"
        xmlns:views="clr-namespace:AgbSynth.App.Views.Settings"
        xmlns:mixerViews="clr-namespace:AgbSynth.App.Views.Mixer"
        xmlns:vm="clr-namespace:AgbSynth.App.ViewModels"
        x:Class="AgbSynth.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280"
        Height="780"
        MinWidth="1040"
        MinHeight="680"
        Title="{Binding WindowTitle}"
        Background="Transparent"
        KeyDown="OnWindowKeyDown"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.Resources>
    <DataTemplate x:Key="KeySplitOptionTemplate" x:DataType="vm:KeySplitOption">
      <TextBlock Text="{Binding FileDisplay}"
                 FontFamily="Consolas"
                 FontSize="10"
                 Foreground="{DynamicResource AppTextPrimaryBrush}"
                 TextTrimming="CharacterEllipsis"/>
    </DataTemplate>
    <DataTemplate x:Key="DrumSetOptionTemplate" x:DataType="vm:DrumSetOption">
      <TextBlock Text="{Binding FileDisplay}"
                 FontFamily="Consolas"
                 FontSize="10"
                 Foreground="{DynamicResource AppTextPrimaryBrush}"
                 TextTrimming="CharacterEllipsis"/>
    </DataTemplate>
    <DataTemplate x:Key="VoiceTableRowTemplate" x:DataType="vm:VoiceRow">
      <Border Height="20"
              Width="984"
              HorizontalAlignment="Left"
              Background="{Binding RowBackground}"
              ClipToBounds="True"
              PointerEntered="OnTableRowPointerEntered"
              PointerExited="OnTableRowPointerExited"
              PointerPressed="OnVoiceRowPointerPressed"
              DoubleTapped="OnVoiceDoubleTapped">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Move Up" Click="OnVoiceRowMoveUpClicked"/>
            <MenuItem Header="Move Down" Click="OnVoiceRowMoveDownClicked"/>
            <Separator/>
            <MenuItem Header="Copy" Click="OnVoiceRowCopyClicked"/>
            <MenuItem Header="Paste" Click="OnVoiceRowPasteClicked"/>
            <Separator/>
            <MenuItem Header="Reset to Default" Click="OnVoiceRowResetClicked"/>
          </ContextMenu>
        </Border.ContextMenu>
        <Grid ColumnDefinitions="16,48,64,160,132,153,48,48,36,48,40,40,40,40,44">
          <Border Grid.Column="0" Background="{DynamicResource AppTableHoverBrush}">
            <TextBlock Classes="voiceTableText"
                       Text="..."
                       FontSize="14"
                       HorizontalAlignment="Center"/>
          </Border>
          <Border Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBlock Classes="voiceTableText" Text="{Binding IndexText}" HorizontalAlignment="Center"/>
          </Border>
          <Border Grid.Column="2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBlock Classes="voiceTableText"
                       Text="{Binding UsageText}"
                       Margin="4,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
          </Border>
          <Border Grid.Column="3" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell" Text="{Binding Label, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="4" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <ComboBox Classes="voiceTableCellCombo"
                      ItemsSource="{Binding AvailableTypeOptions}"
                      SelectedItem="{Binding SelectedTypeOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:VoiceTypeOption">
                  <TextBlock Text="{Binding Display}"
                             FontFamily="Consolas"
                             FontSize="10"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Border>
          <Border Grid.Column="5" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <Grid>
              <Button Classes="voiceTableDataButton"
                      IsVisible="{Binding IsFileDataVisible}"
                      Click="OnVoiceDataSelectClicked">
                <TextBlock Text="{Binding DataDisplay}"
                           TextTrimming="CharacterEllipsis"/>
              </Button>
              <ComboBox Classes="voiceTableCellCombo"
                        IsVisible="{Binding IsPsgSquareDataVisible}"
                        ItemsSource="{Binding AvailableSquareDutyOptions}"
                        SelectedItem="{Binding SelectedSquareDutyOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VoiceDataOption">
                    <TextBlock Text="{Binding Display}"
                               FontFamily="Consolas"
                               FontSize="10"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <ComboBox Classes="voiceTableCellCombo"
                        IsVisible="{Binding IsPsgNoiseDataVisible}"
                        ItemsSource="{Binding AvailableNoiseControlOptions}"
                        SelectedItem="{Binding SelectedNoiseControlOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VoiceDataOption">
                    <TextBlock Text="{Binding Display}"
                               FontFamily="Consolas"
                               FontSize="10"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
          </Border>
          <Border Grid.Column="6" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding KeyName, Mode=TwoWay}" IsEnabled="{Binding IsBaseKeyEditable}"/>
          </Border>
          <Border Grid.Column="7" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Length, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="8" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <ToggleButton Classes="voiceTableTinyToggle"
                          IsChecked="{Binding PanOverrideEnabled, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="9" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell"
                     Text="{Binding PanSigned, Mode=TwoWay}"
                     IsEnabled="{Binding PanOverrideEnabled}"/>
          </Border>
          <Border Grid.Column="10" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Attack, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="11" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Decay, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="12" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Sustain, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="13" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Release, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="14">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="2">
              <Button Classes="voiceTableIconButton" Click="OnVoiceRowResetClicked" ToolTip.Tip="Reset to Square 1">
                <Viewbox Width="13" Height="13">
                  <Canvas Width="16" Height="16">
                    <Path Classes="voiceTableMutedIconPath"
                          Data="M9.75 6.25L6.25 9.75M6.25 6.25L9.75 9.75M13 8C13 10.7614 10.7614 13 8 13C5.23858 13 3 10.7614 3 8C3 5.23858 5.23858 3 8 3C10.7614 3 13 5.23858 13 8Z"/>
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="voiceTableIconButton" Click="OnVoiceRowMoreClicked" ToolTip.Tip="More">
                <Viewbox Width="14" Height="14">
                  <Canvas Width="16" Height="16">
                    <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 8.66667C8.3682 8.66667 8.66668 8.36819 8.66668 8.00001C8.66668 7.63182 8.3682 7.33334 8.00001 7.33334C7.63182 7.33334 7.33334 7.63182 7.33334 8.00001C7.33334 8.36819 7.63182 8.66667 8.00001 8.66667Z"/>
                    <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 4C8.3682 4 8.66668 3.70153 8.66668 3.33334C8.66668 2.96515 8.3682 2.66667 8.00001 2.66667C7.63182 2.66667 7.33334 2.96515 7.33334 3.33334C7.33334 3.70153 7.63182 4 8.00001 4Z"/>
                    <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 13.3333C8.3682 13.3333 8.66668 13.0349 8.66668 12.6667C8.66668 12.2985 8.3682 12 8.00001 12C7.63182 12 7.33334 12.2985 7.33334 12.6667C7.33334 13.0349 7.63182 13.3333 8.00001 13.3333Z"/>
                  </Canvas>
                </Viewbox>
              </Button>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </DataTemplate>
    <DataTemplate x:Key="KeySplitVoiceRowTemplate" x:DataType="vm:VoiceRow">
      <Border Height="20"
              Width="984"
              HorizontalAlignment="Left"
              Background="{Binding RowBackground}"
              ClipToBounds="True"
              PointerEntered="OnTableRowPointerEntered"
              PointerExited="OnTableRowPointerExited"
              PointerPressed="OnVoiceRowPointerPressed"
              DoubleTapped="OnVoiceDoubleTapped">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Insert Above" Click="OnKeySplitRowInsertAboveClicked"/>
            <MenuItem Header="Insert Below" Click="OnKeySplitRowInsertBelowClicked"/>
            <MenuItem Header="Copy Row" Click="OnKeySplitRowCopyClicked"/>
            <MenuItem Header="Paste Below" Click="OnKeySplitRowPasteClicked"/>
            <Separator/>
            <MenuItem Header="Delete" Click="OnKeySplitRowDeleteClicked"/>
          </ContextMenu>
        </Border.ContextMenu>
        <Grid ColumnDefinitions="16,48,180,168,183,48,48,36,48,40,40,40,40,44">
          <Border Grid.Column="0" Background="{DynamicResource AppTableHoverBrush}">
            <TextBlock Classes="voiceTableText" Text="..." FontSize="14" HorizontalAlignment="Center"/>
          </Border>
          <Border Grid.Column="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBlock Classes="voiceTableText" Text="{Binding IndexText}" HorizontalAlignment="Center"/>
          </Border>
          <Border Grid.Column="2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell" Text="{Binding Label, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="3" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <ComboBox Classes="voiceTableCellCombo"
                      ItemsSource="{Binding AvailableTypeOptions}"
                      SelectedItem="{Binding SelectedTypeOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:VoiceTypeOption">
                  <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="10"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Border>
          <Border Grid.Column="4" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <Grid>
              <Button Classes="voiceTableDataButton"
                      IsVisible="{Binding IsFileDataVisible}"
                      Click="OnVoiceDataSelectClicked">
                <TextBlock Text="{Binding DataDisplay}" TextTrimming="CharacterEllipsis"/>
              </Button>
              <ComboBox Classes="voiceTableCellCombo"
                        IsVisible="{Binding IsPsgSquareDataVisible}"
                        ItemsSource="{Binding AvailableSquareDutyOptions}"
                        SelectedItem="{Binding SelectedSquareDutyOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VoiceDataOption">
                    <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="10"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <ComboBox Classes="voiceTableCellCombo"
                        IsVisible="{Binding IsPsgNoiseDataVisible}"
                        ItemsSource="{Binding AvailableNoiseControlOptions}"
                        SelectedItem="{Binding SelectedNoiseControlOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:VoiceDataOption">
                    <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="10"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
          </Border>
          <Border Grid.Column="5" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding KeyName, Mode=TwoWay}" IsEnabled="{Binding IsBaseKeyEditable}"/>
          </Border>
          <Border Grid.Column="6" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Length, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="7" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <ToggleButton Classes="voiceTableTinyToggle" IsChecked="{Binding PanOverrideEnabled, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="8" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding PanSigned, Mode=TwoWay}" IsEnabled="{Binding PanOverrideEnabled}"/>
          </Border>
          <Border Grid.Column="9" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Attack, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="10" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Decay, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="11" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Sustain, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="12" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <TextBox Classes="voiceTableCell voiceTableNumberCell" Text="{Binding Release, Mode=TwoWay}"/>
          </Border>
          <Border Grid.Column="13">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
              <Button Classes="voiceTableIconButton" Click="OnKeySplitRowDeleteClicked" ToolTip.Tip="Delete Region">
                <Viewbox Width="13" Height="13">
                  <Canvas Width="16" Height="16">
                    <Path Classes="voiceTableMutedIconPath"
                          Data="M9.75 6.25L6.25 9.75M6.25 6.25L9.75 9.75M13 8C13 10.7614 10.7614 13 8 13C5.23858 13 3 10.7614 3 8C3 5.23858 5.23858 3 8 3C10.7614 3 13 5.23858 13 8Z"/>
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="voiceTableIconButton" Click="OnKeySplitRowMoreClicked" ToolTip.Tip="More">
                <Viewbox Width="14" Height="14">
                  <Canvas Width="16" Height="16">
                    <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 8.66667C8.3682 8.66667 8.66668 8.36819 8.66668 8.00001C8.66668 7.63182 8.3682 7.33334 8.00001 7.33334C7.63182 7.33334 7.33334 7.63182 7.33334 8.00001C7.33334 8.36819 7.63182 8.66667 8.00001 8.66667Z"/>
                    <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 4C8.3682 4 8.66668 3.70153 8.66668 3.33334C8.66668 2.96515 8.3682 2.66667 8.00001 2.66667C7.63182 2.66667 7.33334 2.96515 7.33334 3.33334C7.33334 3.70153 7.63182 4 8.00001 4Z"/>
                    <Path Classes="voiceTableIconPath" StrokeThickness="1.6" Data="M8.00001 13.3333C8.3682 13.3333 8.66668 13.0349 8.66668 12.6667C8.66668 12.2985 8.3682 12 8.00001 12C7.63182 12 7.33334 12.2985 7.33334 12.6667C7.33334 13.0349 7.63182 13.3333 8.00001 13.3333Z"/>
                  </Canvas>
                </Viewbox>
              </Button>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.titleBarIcon">
      <Setter Property="Width" Value="32"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="MinWidth" Value="32"/>
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="CornerRadius" Value="5"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.titleBarIcon:pointerover">
      <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.titleBarIcon:pressed">
      <Setter Property="Background" Value="{DynamicResource AppControlPressedBrush}"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.windowClose:pointerover">
      <Setter Property="Background" Value="#C42B1C"/>
    </Style>
    <Style Selector="Button.titleBarIcon:disabled">
      <Setter Property="Opacity" Value="0.28"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Path.titleIconPath">
      <Setter Property="Stroke" Value="{DynamicResource AppTextSecondaryBrush}"/>
      <Setter Property="StrokeThickness" Value="1.8"/>
      <Setter Property="StrokeLineCap" Value="Round"/>
      <Setter Property="StrokeJoin" Value="Round"/>
    </Style>
    <Style Selector="TabControl.sideNavTabs">
      <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="TabItem.sideNav">
      <Setter Property="Width" Value="220"/>
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="Margin" Value="14,6,14,0"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>
    <Style Selector="TabItem.sideNav:pointerover">
      <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}"/>
    </Style>
    <Style Selector="TabItem.sideNav:pressed">
      <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
    </Style>
    <Style Selector="TabItem.sideNav:selected">
      <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
    </Style>
    <Style Selector="TabItem.sideNav:selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
    </Style>
    <Style Selector="TabItem.sideNav:selected:pressed">
      <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
    </Style>
    <Style Selector="TabItem.hiddenNav">
      <Setter Property="Width" Value="0"/>
      <Setter Property="MinWidth" Value="0"/>
      <Setter Property="Height" Value="0"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>
    <Style Selector="Button.sideNavButton">
      <Setter Property="Width" Value="220"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="Margin" Value="14,6,14,0"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.sideNavButton:pointerover">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.sideNavButton:pressed">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Path.sideNavButtonIcon">
      <Setter Property="Stroke" Value="{DynamicResource AppTextPrimaryBrush}"/>
      <Setter Property="StrokeThickness" Value="2.1"/>
      <Setter Property="StrokeLineCap" Value="Round"/>
      <Setter Property="StrokeJoin" Value="Round"/>
      <Setter Property="Margin" Value="2"/>
    </Style>
    <Style Selector="Path.sideNavIcon">
      <Setter Property="Stroke" Value="{DynamicResource AppTextPrimaryBrush}"/>
      <Setter Property="StrokeThickness" Value="2.1"/>
      <Setter Property="StrokeLineCap" Value="Round"/>
      <Setter Property="StrokeJoin" Value="Round"/>
      <Setter Property="Margin" Value="2"/>
    </Style>
    <Style Selector="Button.playAreaIcon">
      <Setter Property="Width" Value="32"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="MinWidth" Value="32"/>
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.playAreaIcon:pointerover">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
<Style Selector="Button.playAreaIcon:pressed">
      <Setter Property="Background" Value="{DynamicResource AppControlPressedBrush}"/>
    </Style>
    <Style Selector="Button.playAreaIcon:disabled">
      <Setter Property="Opacity" Value="0.28"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ComboBox.playAreaSelect">
      <Setter Property="Width" Value="220"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="MinHeight" Value="24"/>
      <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppControlBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>
    <Style Selector="Button.recording">
      <Setter Property="Background" Value="#6A2727"/>
    </Style>
    <Style Selector="Path.playAreaIconPath">
      <Setter Property="Stroke" Value="{DynamicResource AppTextPrimaryBrush}"/>
      <Setter Property="StrokeThickness" Value="2"/>
      <Setter Property="StrokeLineCap" Value="Round"/>
      <Setter Property="StrokeJoin" Value="Round"/>
    </Style>
    <Style Selector="TextBlock.voiceTableText">
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBox.voiceTableCell">
      <Setter Property="Height" Value="18"/>
      <Setter Property="MinHeight" Value="18"/>
      <Setter Property="MaxHeight" Value="18"/>
      <Setter Property="Padding" Value="4,0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>
    <Style Selector="TextBox.voiceTableNumberCell">
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ComboBox.voiceTableCellCombo">
      <Setter Property="Height" Value="18"/>
      <Setter Property="MinHeight" Value="18"/>
      <Setter Property="MaxHeight" Value="18"/>
      <Setter Property="Padding" Value="4,0,0,0"/>
