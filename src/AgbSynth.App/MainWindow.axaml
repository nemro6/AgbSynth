                    <Path Classes="songTableIconPath" Data="M4.16663 12.5H3.33329C2.89127 12.5 2.46734 12.3244 2.15478 12.0118C1.84222 11.6993 1.66663 11.2754 1.66663 10.8333V3.33333C1.66663 2.89131 1.84222 2.46738 2.15478 2.15482C2.46734 1.84226 2.89127 1.66667 3.33329 1.66667H10.8333C11.2753 1.66667 11.6992 1.84226 12.0118 2.15482C12.3244 2.46738 12.5 2.89131 12.5 3.33333V4.16667M9.16663 7.5H16.6666C17.5871 7.5 18.3333 8.24619 18.3333 9.16667V16.6667C18.3333 17.5871 17.5871 18.3333 16.6666 18.3333H9.16663C8.24615 18.3333 7.49996 17.5871 7.49996 16.6667V9.16667C7.49996 8.24619 8.24615 7.5 9.16663 7.5Z"/>
                  </Viewbox>
                </Button>
