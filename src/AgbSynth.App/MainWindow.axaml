                      PointerEntered="OnTableRowPointerEntered"
                      PointerExited="OnTableRowPointerExited"
                      PointerPressed="OnSongHeaderRowPointerPressed">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Insert Above" Click="OnSongHeaderRowInsertAboveClicked"/>
                    <MenuItem Header="Insert Below" Click="OnSongHeaderRowInsertBelowClicked"/>
                    <MenuItem Header="Copy Row" Click="OnSongHeaderRowCopyClicked"/>
                    <MenuItem Header="Paste Below" Click="OnSongHeaderRowPasteClicked"/>
