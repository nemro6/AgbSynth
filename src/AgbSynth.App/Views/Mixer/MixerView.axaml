<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AgbSynth.App.Controls"
             xmlns:vm="clr-namespace:AgbSynth.App.ViewModels"
             x:Class="AgbSynth.App.Views.Mixer.MixerView"
             x:DataType="vm:MainWindowViewModel">
<Border Padding="0"
        Background="{DynamicResource AppWindowBackgroundBrush}">
  <Border.Styles>
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
    </Style>
    <Style Selector="Border.mixerMuteButton">
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="MinWidth" Value="16"/>
      <Setter Property="MinHeight" Value="16"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.mixerAlertButton">
      <Setter Property="Width" Value="20"/>
      <Setter Property="Height" Value="20"/>
      <Setter Property="MinWidth" Value="20"/>
      <Setter Property="MinHeight" Value="20"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
  </Border.Styles>

  <Border.Resources>
    <DataTemplate x:Key="MixerStripTemplate" x:DataType="vm:AgbMixerStrip">
      <Grid Width="1000"
            Height="32"
            Margin="0,4,0,0"
            ColumnDefinitions="128,16,17,16,16,16,256,16,32,16,96,16,96,16,96,16,96,16,20,*">
        <Border Grid.Column="0"
                Height="24"
                Background="{DynamicResource AppChromeBackgroundBrush}"
                CornerRadius="6"
                Padding="8,0"
                VerticalAlignment="Center">
          <Grid RowDefinitions="12,12">
            <TextBlock Grid.Row="0"
                       Text="{Binding ProgramDisplay}"
                       FontSize="9"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       VerticalAlignment="Bottom"/>
            <TextBlock Grid.Row="1"
                       Text="{Binding InstrumentLabel}"
                       FontSize="9"
                       Foreground="{DynamicResource AppTextMutedBrush}"
                       TextTrimming="CharacterEllipsis"/>
          </Grid>
        </Border>

        <TextBlock Grid.Column="2"
                   Text="{Binding ActiveNoteText}"
                   FontSize="11"
                   Foreground="{DynamicResource AppTextSecondaryBrush}"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>

        <Border Grid.Column="4"
                Classes="mixerMuteButton"
                Background="{Binding MuteBrush}"
                PointerPressed="OnMixerMutePointerPressed"
                ToolTip.Tip="Left click: mute / Right click: solo"
                VerticalAlignment="Center"/>

        <Border Grid.Column="6"
                Width="256"
                Height="32"
                Background="{DynamicResource AppBorderBrush}"
                CornerRadius="6"
                ClipToBounds="True">
          <Grid>
            <Border Width="{Binding MacLevelWidth}"
                    HorizontalAlignment="Left"
                    CornerRadius="6"
                    ClipToBounds="True">
              <Border Width="256"
                      HorizontalAlignment="Left"
                      CornerRadius="6">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#0ACB2C" Offset="0"/>
                    <GradientStop Color="#53C711" Offset="0.55"/>
                    <GradientStop Color="#D6CB18" Offset="0.82"/>
                    <GradientStop Color="#F05A36" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
            </Border>
            <Canvas>
              <Border Canvas.Left="{Binding MacPeakLeft}"
                      Width="2"
                      Height="28"
                      Canvas.Top="2"
                      IsVisible="{Binding HasPeakLevel}"
                      Background="{DynamicResource AppTextPrimaryBrush}"
                      CornerRadius="1"/>
            </Canvas>
          </Grid>
        </Border>

        <Grid Grid.Column="8"
              Width="32"
              Height="32"
              VerticalAlignment="Center">
          <Ellipse Width="24"
                   Height="24"
                   Fill="{DynamicResource AppBorderBrush}"
                   Opacity="0.92"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
          <Ellipse Width="4"
                   Height="4"
                   Fill="{DynamicResource AppSurfaceBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
          <Grid Width="24"
                Height="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderTransformOrigin="50%,50%">
            <Grid.RenderTransform>
              <RotateTransform Angle="{Binding PanAngle}"/>
            </Grid.RenderTransform>
            <Border Width="2"
                    Height="8"
                    Background="{DynamicResource AppChromeBackgroundBrush}"
                    CornerRadius="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,3,0,0"/>
          </Grid>
        </Grid>

        <StackPanel Grid.Column="10" Spacing="4" VerticalAlignment="Center">
          <Grid Height="14">
            <Border Background="{DynamicResource AppBorderBrush}" CornerRadius="5"/>
            <Border Width="{Binding MacVolumeWidth}" HorizontalAlignment="Left" Background="{Binding VolumeMeterBrush}" CornerRadius="5"/>
            <TextBlock Text="{Binding Volume}" FontSize="8" Foreground="{DynamicResource AppTextPrimaryBrush}" TextAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
          <Grid Height="14">
            <Border Background="{DynamicResource AppBorderBrush}" CornerRadius="5"/>
            <Border Width="{Binding VelocityWidth}" HorizontalAlignment="Left" Background="{Binding VelocityMeterBrush}" CornerRadius="5"/>
            <TextBlock Text="{Binding Velocity}" FontSize="8" Foreground="{DynamicResource AppTextPrimaryBrush}" TextAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>

        <StackPanel Grid.Column="12" Spacing="4" VerticalAlignment="Center">
          <Grid Height="14">
            <Border Background="{DynamicResource AppBorderBrush}" CornerRadius="5"/>
            <Border Width="{Binding ModSpeedWidth}" HorizontalAlignment="Left" Background="{Binding ModSpeedMeterBrush}" CornerRadius="5"/>
            <TextBlock Text="{Binding ModSpeed}" FontSize="8" Foreground="{DynamicResource AppTextPrimaryBrush}" TextAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
          <Grid Height="14">
            <Border Background="{DynamicResource AppBorderBrush}" CornerRadius="5"/>
            <Border Width="{Binding ModDelayWidth}" HorizontalAlignment="Left" Background="{Binding ModDelayMeterBrush}" CornerRadius="5"/>
            <TextBlock Text="{Binding ModDelay}" FontSize="8" Foreground="{DynamicResource AppTextPrimaryBrush}" TextAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>

        <StackPanel Grid.Column="14" Spacing="4" VerticalAlignment="Center">
          <Grid Height="14" ClipToBounds="True">
            <Border Background="{DynamicResource AppBorderBrush}" CornerRadius="5"/>
            <Border Background="{Binding ModulationMeterBrush}" CornerRadius="5" Opacity="0.55"/>
            <TextBlock Text="{Binding ModTypeLabel}" FontSize="9" Foreground="{DynamicResource AppTextPrimaryBrush}" TextAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
          <Grid Height="14" ColumnDefinitions="*,*" ClipToBounds="True">
            <Border Grid.ColumnSpan="2" Background="{DynamicResource AppBorderBrush}" CornerRadius="5"/>
            <Border Grid.ColumnSpan="2"
                    Width="{Binding MacModulationWidth}"
                    HorizontalAlignment="Left"
                    Background="{Binding ModulationMeterBrush}"
                    CornerRadius="5"
                    Opacity="0.7"/>
            <Grid Grid.ColumnSpan="2"
                  ColumnDefinitions="*,*"
                  Height="2"
                  VerticalAlignment="Bottom"
                  ClipToBounds="True">
              <Border Grid.Column="0"
                      Width="{Binding ModSwingNegWidth}"
                      HorizontalAlignment="Right"
                      Background="{Binding ModulationPulseBrush}"
                      CornerRadius="1"/>
              <Border Grid.Column="1"
                      Width="{Binding ModSwingPosWidth}"
                      HorizontalAlignment="Left"
                      Background="{Binding ModulationPulseBrush}"
                      CornerRadius="1"/>
            </Grid>
            <TextBlock Grid.ColumnSpan="2" Text="{Binding Modulation}" FontSize="8" Foreground="#888" TextAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>

        <StackPanel Grid.Column="16" Spacing="4" VerticalAlignment="Center">
          <Grid Height="14">
            <Border Background="{DynamicResource AppBorderBrush}" CornerRadius="5"/>
            <Border Width="{Binding MacBendRangeWidth}" HorizontalAlignment="Left" Background="{Binding BendRangeMeterBrush}" CornerRadius="5" Opacity="0.82"/>
            <TextBlock Text="{Binding BendRange}" FontSize="8" Foreground="{DynamicResource AppTextPrimaryBrush}" TextAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
          <Grid Height="14" ColumnDefinitions="*,*">
            <Border Grid.ColumnSpan="2" Background="{DynamicResource AppBorderBrush}" CornerRadius="5"/>
            <Border Grid.Column="0" Width="{Binding MacPitchBendLeftWidth}" HorizontalAlignment="Right" Background="{Binding PitchBendMeterBrush}" CornerRadius="5"/>
            <Border Grid.Column="1" Width="{Binding MacPitchBendRightWidth}" HorizontalAlignment="Left" Background="{Binding PitchBendMeterBrush}" CornerRadius="5"/>
            <TextBlock Grid.ColumnSpan="2" Text="{Binding PitchBend}" FontSize="8" Foreground="{DynamicResource AppTextPrimaryBrush}" TextAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>

        <Button Grid.Column="18"
                Classes="mixerAlertButton"
                ToolTip.Tip="{Binding IssueLog}"
                Opacity="{Binding AlertOpacity}"
                Click="OnMixerAlertClicked">
          <Viewbox Width="18" Height="18">
            <Path Stroke="{DynamicResource AppTextPrimaryBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Data="M9.99996 6.66666V9.99999M9.99996 13.3333H10.0083M18.3333 9.99999C18.3333 14.6024 14.6023 18.3333 9.99996 18.3333C5.39759 18.3333 1.66663 14.6024 1.66663 9.99999C1.66663 5.39762 5.39759 1.66666 9.99996 1.66666C14.6023 1.66666 18.3333 5.39762 18.3333 9.99999Z"/>
          </Viewbox>
        </Button>
      </Grid>
    </DataTemplate>
  </Border.Resources>

  <Grid RowDefinitions="Auto,*">
    <ScrollViewer Grid.Row="0"
                  Margin="0,14,0,0"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled">
      <ItemsControl ItemsSource="{Binding MixerStripsByChannel}"
                    ItemTemplate="{StaticResource MixerStripTemplate}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Vertical"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
      </ItemsControl>
    </ScrollViewer>

    <Border Grid.Row="1"
            Margin="0,8,20,0"
            Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppControlPressedBrush}"
            BorderThickness="0,1,0,0"
            Padding="8,4"
            MinHeight="0">
      <controls:PianoKeyboard MinNote="0"
                              MaxNote="127"
                              MinHeight="0"
                              VerticalAlignment="Stretch"
                              IsHitTestVisible="False"
                              ActiveNoteChannelMasks="{Binding ActiveNoteChannelMasks}"
                              ChannelBrushes="{Binding MixerKeyboardChannelBrushes}"/>
    </Border>
  </Grid>
</Border>
</UserControl>
